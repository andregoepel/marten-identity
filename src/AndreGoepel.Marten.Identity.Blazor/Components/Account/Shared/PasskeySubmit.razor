@using AndreGoepel.Marten.Identity.Users
@using Radzen.Blazor

@implements IAsyncDisposable

@inject IJSRuntime JSRuntime

<button type="button"
        @attributes="AdditionalAttributes"
        class="rz-button rz-button-md rz-variant-filled rz-primary rz-shade-default"
        disabled="@isBusy"
        @onclick="HandleClickAsync">
    @ChildContent
</button>

@code {
    [Parameter, EditorRequired] public PasskeyOperation Operation { get; set; }
    [Parameter, EditorRequired] public string OptionsEndpointUrl { get; set; } = default!;
    [Parameter, EditorRequired] public string ActionEndpointUrl { get; set; } = default!;
    [Parameter] public EventCallback<string> OnSuccess { get; set; }
    [Parameter] public EventCallback<string> OnError { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private bool isBusy;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./_content/AndreGoepel.Marten.Identity.Blazor/Components/Account/Shared/PasskeySubmit.razor.js");
    }

    private async Task HandleClickAsync()
    {
        if (_module is null) return;

        isBusy = true;
        StateHasChanged();

        try
        {
            var fnName = Operation == PasskeyOperation.Create ? "createCredential" : "requestCredential";
            var result = await _module.InvokeAsync<string>(fnName, OptionsEndpointUrl, ActionEndpointUrl);
            await OnSuccess.InvokeAsync(result);
        }
        catch (JSException ex) when (ex.Message.Contains("AbortError"))
        {
            // User cancelled — no action needed
        }
        catch (JSException ex)
        {
            var msg = ex.Message.Contains("NotAllowedError")
                ? "No passkey was provided by the authenticator."
                : ex.Message;
            await OnError.InvokeAsync(msg);
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already disconnecting due to forced navigation — safe to ignore
            }
        }
    }
}
