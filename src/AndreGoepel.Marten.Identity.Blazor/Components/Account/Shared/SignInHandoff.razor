@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@* When a handle is set, render a hidden form and POST it to the cookie sign-in
   middleware. The handle travels in the request body — never the URL (#40). The
   AntiforgeryToken satisfies UseAntiforgery()'s validation of the form post; the
   middleware's same-origin check stays as a second layer. *@
@if (!string.IsNullOrEmpty(Handle))
{
    <form @ref="_form" method="post" action="@Action" style="display:none" aria-hidden="true">
        <AntiforgeryToken />
        <input type="hidden" name="token" value="@Handle" />
    </form>
}

@code {
    /// <summary>The cookie-sign-in path to post to (e.g. <c>/login</c>).</summary>
    [Parameter, EditorRequired]
    public string Action { get; set; } = default!;

    /// <summary>The opaque single-use handoff handle. Setting it triggers the POST.</summary>
    [Parameter, EditorRequired]
    public string? Handle { get; set; }

    private ElementReference _form;
    private IJSObjectReference? _module;
    private bool _submitted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrEmpty(Handle) || _submitted)
            return;

        _submitted = true;
        _module ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/AndreGoepel.Marten.Identity.Blazor/Components/Account/Shared/SignInHandoff.razor.js");
        await _module.InvokeVoidAsync("submitForm", _form);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already tearing down due to the navigation — safe to ignore.
            }
        }
    }
}
