@page "/Account/ForgotPasswordConfirmation"
@attribute [AllowAnonymous]
@inherits LocalizedComponentBase

@inject NavigationManager NavigationManager

<AppPageTitle Title="@T("ForgotPasswordConfirmation.PageTitle")" />

<div class="rz-p-4 rz-p-md-8">
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Center">

            <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">@T("ForgotPasswordConfirmation.Heading")</RadzenText>

            <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" Variant="Variant.Flat" AllowClose="false">
                @T("ForgotPasswordConfirmation.Detail")
            </RadzenAlert>

            <RadzenButton Text="@T("ForgotPasswordConfirmation.BackToLogin")"
                          ButtonStyle="ButtonStyle.Primary"
                          Click=@(() => NavigationManager.NavigateTo("/Account/Login")) />

        </RadzenStack>
    </RadzenCard>
</div>

