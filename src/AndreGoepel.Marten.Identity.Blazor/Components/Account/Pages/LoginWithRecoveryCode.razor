@page "/Account/LoginWithRecoveryCode"
@attribute [AllowAnonymous]
@layout LoginLayout
@rendermode InteractiveServer
@inherits IdentityLocalizedComponentBase

@inject NotificationService NotificationService
@inject LoginTokenProtector LoginTokens

<AppPageTitle Title="@T("LoginWithRecoveryCode.PageTitle")" />

<div class="ag-login-head">
    <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4" Text="@T("LoginWithRecoveryCode.Heading")" />
    <RadzenText TextStyle="TextStyle.Body2" class="ag-login-sub" Text="@T("LoginWithRecoveryCode.Subheading")" />
</div>

<RadzenTemplateForm TItem="InputModel" Data="@Input" Submit="@OnSubmitAsync">
    <RadzenStack Gap="1.25rem">

        <FormField Label="@T("LoginWithRecoveryCode.CodeLabel")" For="RecoveryCode">
            <RadzenTextBox @bind-Value="@Input.RecoveryCode"
                           Name="RecoveryCode"
                           Placeholder="@T("LoginWithRecoveryCode.CodePlaceholder")"
                           AutoCompleteType="AutoCompleteType.Off"
                           Style="width:100%" />
            <RadzenRequiredValidator Component="RecoveryCode" Text="@T("LoginWithRecoveryCode.CodeRequired")" />
        </FormField>

        <div class="ag-login-actions">
            <RadzenButton ButtonType="ButtonType.Submit"
                          Text="@T("LoginWithRecoveryCode.Submit")"
                          ButtonStyle="ButtonStyle.Primary"
                          IsBusy="@_isProcessing"
                          BusyText="@T("LoginWithRecoveryCode.Verifying")" />
        </div>

    </RadzenStack>
</RadzenTemplateForm>

<div class="ag-login-footer-links">
    <span class="ag-login-resend">
        <RadzenLink Path="/Account/LoginWith2fa" Text="@T("LoginWithRecoveryCode.UseAuthenticatorCode")" />
    </span>
</div>

<SignInHandoff Action="/loginrecovery" Handle="@_handle" />

@code {
    private InputModel Input { get; set; } = new();
    private bool _isProcessing;
    private string? _handle;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        if (Error == "invalid")
        {
            NotificationService.Notify(NotificationSeverity.Error, T("LoginWithRecoveryCode.ErrorTitle"), T("LoginWithRecoveryCode.InvalidCode"));
        }
    }

    private async Task OnSubmitAsync(InputModel model)
    {
        _isProcessing = true;

        _handle = LoginTokens.Protect(
            new RecoveryCodeLoginInfo(Code: model.RecoveryCode, ReturnUrl: ReturnUrl)
        );
    }

    private sealed class InputModel
    {
        [Required]
        public string RecoveryCode { get; set; } = "";
    }

}
