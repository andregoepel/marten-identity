@page "/Account/LoginWithRecoveryCode"
@attribute [AllowAnonymous]
@layout LoginLayout
@rendermode InteractiveServer


@inject NotificationService NotificationService
@inject LoginTokenProtector LoginTokens

<IdentityPageTitle Title="Recovery code verification" />

<SectionContent SectionName="login-tagline">Use a recovery code to regain access.</SectionContent>

<RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4">Recovery code verification</RadzenText>

<RadzenTemplateForm TItem="InputModel" Data="@Input" Submit="@OnSubmitAsync">
    <RadzenStack Gap="1.25rem">

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
            <RadzenLabel Text="Recovery code" Component="RecoveryCode" Style="width: 10rem; flex-shrink: 0;" />
            <RadzenStack Gap="0.25rem" Style="flex: 1;">
                <RadzenTextBox @bind-Value="@Input.RecoveryCode"
                               Name="RecoveryCode"
                               Placeholder="Enter recovery code"
                               AutoCompleteType="AutoCompleteType.Off"
                               Style="width:100%" />
                <RadzenRequiredValidator Component="RecoveryCode" Text="Recovery code is required" />
            </RadzenStack>
        </RadzenStack>

        <div class="login-action-row">
            <RadzenButton ButtonType="ButtonType.Submit"
                          Text="Log in"
                          ButtonStyle="ButtonStyle.Primary"
                          IsBusy="@_isProcessing"
                          BusyText="Verifying..." />

            <RadzenLink Path="/Account/LoginWith2fa" Text="Use an authenticator code instead" />
        </div>

    </RadzenStack>
</RadzenTemplateForm>

<SignInHandoff Action="/loginrecovery" Handle="@_handle" />

@code {
    private InputModel Input { get; set; } = new();
    private bool _isProcessing;
    private string? _handle;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        if (Error == "invalid")
        {
            NotificationService.Notify(NotificationSeverity.Error, "Recovery Code Error", "Invalid recovery code entered.");
        }
    }

    private async Task OnSubmitAsync(InputModel model)
    {
        _isProcessing = true;

        _handle = LoginTokens.Protect(
            new RecoveryCodeLoginInfo(Code: model.RecoveryCode, ReturnUrl: ReturnUrl)
        );
    }

    private sealed class InputModel
    {
        [Required]
        public string RecoveryCode { get; set; } = "";
    }
}
