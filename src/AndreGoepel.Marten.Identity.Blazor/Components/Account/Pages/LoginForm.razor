@inherits IdentityLocalizedComponentBase
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject IPasswordHasher<User> PasswordHasher
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject LoginTokenProtector LoginTokens

<RadzenTemplateForm TItem="InputModel" Data="@Input" Submit="@LoginUser" id="login-form">
    <RadzenStack Gap="1.25rem">

        <RadzenStack Gap="0.4rem">
            <RadzenLabel Text="@T("LoginForm.Email")" Component="Email" />
            <RadzenTextBox @bind-Value="@Input.Email"
                           Name="Email"
                           AutoCompleteType="AutoCompleteType.Username"
                           Placeholder="name@example.com"
                           Style="width:100%" />
            <RadzenRequiredValidator Component="Email" Text="@T("LoginForm.EmailRequired")" />
        </RadzenStack>

        <RadzenStack Gap="0.4rem">
            <div class="ag-login-field-head">
                <RadzenLabel Text="@T("LoginForm.Password")" Component="Password" />
                <RadzenLink Path="Account/ForgotPassword" Text="@T("LoginForm.ForgotPassword")" class="ag-login-forgot" />
            </div>
            <RadzenPassword @bind-Value="Input.Password" Name="Password" Style="width:100%" />
            <RadzenRequiredValidator Component="Password" Text="@T("LoginForm.PasswordRequired")" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenCheckBox @bind-Value="@Input.RememberMe" Name="RememberMe" />
            <RadzenLabel Text="@T("LoginForm.RememberMe")" Component="RememberMe" />
        </RadzenStack>

    </RadzenStack>
</RadzenTemplateForm>

<SignInHandoff Action="/login" Handle="@_handle" />

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? _handle;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
    }

    private async Task LoginUser(InputModel model)
    {
        var user = await UserManager.FindByEmailAsync(model.Email);

        if (user is null)
        {
            // Consume comparable time to a real password verification so a non-existent
            // account is not distinguishable from a wrong password by response latency
            // (user enumeration, CWE-208). The uniform message already hides it in the
            // response body; this closes the timing side channel.
            _ = PasswordHasher.HashPassword(new User(), model.Password);
            NotificationService.Notify(NotificationSeverity.Error, T("LoginForm.LoginErrorTitle"), T("LoginForm.InvalidLoginAttempt"));
            return;
        }

        if (!await SignInManager.CanSignInAsync(user))
        {
            NotificationService.Notify(NotificationSeverity.Error, T("LoginForm.LoginErrorTitle"), T("LoginForm.InvalidLoginAttempt"));
            return;
        }

        if (await UserManager.IsLockedOutAsync(user))
        {
            Logger.LogWarning("User account locked out.");
            NavigationManager.NavigateTo("Account/Lockout");
            return;
        }

        if (!await UserManager.CheckPasswordAsync(user, model.Password))
        {
            await UserManager.AccessFailedAsync(user);
            NotificationService.Notify(NotificationSeverity.Error, T("LoginForm.LoginErrorTitle"), T("LoginForm.InvalidLoginAttempt"));
            return;
        }

        // SignInHandoff POSTs this handle to the cookie-sign-in middleware (body, not URL).
        _handle = LoginTokens.Protect(
            new LoginInfo(model.Email, model.Password, model.RememberMe, ReturnUrl)
        );
    }

    // Validation lives in the markup as RadzenRequiredValidator components. Removing
    // DataAnnotationsValidator (and the Required attributes with it) unifies this form onto
    // the same mechanism every other form in the app uses, and — the reason it matters here —
    // lets the required messages be localized like everything else; a DataAnnotation's error
    // text must be a compile-time constant, so it cannot call into IStringLocalizer (#114).
    private sealed class InputModel
    {
        public string Email { get; set; } = "";

        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}
