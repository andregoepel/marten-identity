@page "/Account/Manage/GenerateRecoveryCodes"
@rendermode InteractiveServer

@inject UserManager<User> UserManager
@inject ILogger<GenerateRecoveryCodes> Logger
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IServiceProvider Services

<AppPageTitle Title="@T("GenerateRecoveryCodes.PageTitle")" Breadcrumb="@T("GenerateRecoveryCodes.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@T("GenerateRecoveryCodes.Heading")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">@T("GenerateRecoveryCodes.Subheading")</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            @if (_recoveryCodes is not null)
            {
                <ShowRecoveryCodes RecoveryCodes="_recoveryCodes.ToArray()" />
            }
            else
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" Variant="Variant.Flat" Icon="warning" AllowClose="false">
                    <strong>@T("GenerateRecoveryCodes.AlertStrong")</strong><br />
                    @T("GenerateRecoveryCodes.AlertLine2")<br />
                    @T("GenerateRecoveryCodes.AlertLine3Prefix")
                    <RadzenLink Path="/Account/Manage/ResetAuthenticator" Text="@T("GenerateRecoveryCodes.AlertLinkText")" />.
                </RadzenAlert>

                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenButton Text="@T("GenerateRecoveryCodes.GenerateButton")"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Size="ButtonSize.Large"
                                  IsBusy="@_isProcessing"
                                  BusyText="@T("GenerateRecoveryCodes.GeneratingBusyText")"
                                  Style="width: 100%; max-width: 360px;"
                                  Click="OnGenerateAsync" />
                </RadzenStack>
            }

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private User? _user;
    private IEnumerable<string>? _recoveryCodes;
    private bool _isProcessing;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = await UserManager.GetUserAsync(authState.User);
        if (_user is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("GenerateRecoveryCodes.ErrorTitle"), T("GenerateRecoveryCodes.UserNotFoundDetail"));
            return;
        }

        var isTwoFactorEnabled = await UserManager.GetTwoFactorEnabledAsync(_user);
        if (!isTwoFactorEnabled)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("GenerateRecoveryCodes.ErrorTitle"), T("GenerateRecoveryCodes.TwoFactorRequiredDetail"));
        }
    }

    private async Task OnGenerateAsync()
    {
        if (_user is null) return;

        _isProcessing = true;

        var userId = await UserManager.GetUserIdAsync(_user);
        _recoveryCodes = await UserManager.GenerateNewTwoFactorRecoveryCodesAsync(_user, 10);
        NotificationService.Notify(NotificationSeverity.Success, T("GenerateRecoveryCodes.GeneratedTitle"), T("GenerateRecoveryCodes.GeneratedDetail"));
        Logger.LogInformation("User with ID '{UserId}' has generated new 2FA recovery codes.", userId);

        _isProcessing = false;
    }

    // Resolved through IServiceProvider rather than an injected IStringLocalizer so the page
    // still renders on a host (or bUnit test) without localization registered.
    private string T(string key) => Services.IdentityText(key);
}
