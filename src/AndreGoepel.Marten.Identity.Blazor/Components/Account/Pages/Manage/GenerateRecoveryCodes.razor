@page "/Account/Manage/GenerateRecoveryCodes"
@rendermode InteractiveServer

@using AndreGoepel.Marten.Identity.Users
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject UserManager<User> UserManager
@inject ILogger<GenerateRecoveryCodes> Logger
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Generate two-factor authentication (2FA) recovery codes – nerdventures.blog</PageTitle>

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Generate Recovery Codes</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Two-factor authentication recovery codes</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            @if (recoveryCodes is not null)
            {
                <ShowRecoveryCodes RecoveryCodes="recoveryCodes.ToArray()" />
            }
            else
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" Variant="Variant.Flat" Icon="warning" AllowClose="false">
                    <strong>Put these codes in a safe place.</strong><br />
                    If you lose your device and don't have the recovery codes you will lose access to your account.<br />
                    Generating new recovery codes does not change the keys used in authenticator apps. If you wish to change
                    the key used in an authenticator app you should
                    <RadzenLink Path="/Account/Manage/ResetAuthenticator" Text="reset your authenticator keys" />.
                </RadzenAlert>

                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenButton Text="Generate Recovery Codes"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Size="ButtonSize.Large"
                                  IsBusy="@isProcessing"
                                  BusyText="Generating..."
                                  Style="width: 100%; max-width: 360px;"
                                  Click="OnGenerateAsync" />
                </RadzenStack>
            }

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private User? user;
    private IEnumerable<string>? recoveryCodes;
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Could not load user profile.");
            return;
        }

        var isTwoFactorEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
        if (!isTwoFactorEnabled)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "You must have 2FA enabled to generate recovery codes.");
        }
    }

    private async Task OnGenerateAsync()
    {
        if (user is null) return;

        isProcessing = true;

        var userId = await UserManager.GetUserIdAsync(user);
        recoveryCodes = await UserManager.GenerateNewTwoFactorRecoveryCodesAsync(user, 10);
        NotificationService.Notify(NotificationSeverity.Success, "Recovery codes generated", "You have generated new recovery codes.");
        Logger.LogInformation("User with ID '{UserId}' has generated new 2FA recovery codes.", userId);

        isProcessing = false;
    }
}
