@page "/Account/Manage/DeletePersonalData"
@rendermode InteractiveServer
@inherits LocalizedComponentBase

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject ILogger<DeletePersonalData> Logger
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager
@inject ConfirmService Confirm

<AppPageTitle Title="@T("DeletePersonalData.PageTitle")" Breadcrumb="@T("DeletePersonalData.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("DeletePersonalData.Heading")"
                    Subtitle="@T("DeletePersonalData.Subtitle")" />

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <!-- Starke Warnung -->
            <RadzenAlert AlertStyle="AlertStyle.Danger"
                         AllowClose="false"
                         Icon="warning"
                         Title="@T("DeletePersonalData.AlertTitle")">
                    @T("DeletePersonalData.AlertBodyPrefix") <strong>@T("DeletePersonalData.AlertBodyStrong")</strong> @T("DeletePersonalData.AlertBodySuffix")
            </RadzenAlert>

            <RadzenTemplateForm TItem="InputModel"
                                Data="@Model"
                                Submit="@OnValidSubmit">
                <RadzenStack Gap="2rem">

                    <RadzenStack Gap="1.5rem">

                        <FormField Label="@T("DeletePersonalData.PasswordLabel")" For="Password">
                            <RadzenPassword @bind-Value="@Model.Password"
                                            Name="Password"
                                            Placeholder="@T("DeletePersonalData.PasswordPlaceholder")"
                                            Style="width:100%" />
                            <RadzenRequiredValidator Component="Password" Text="@T("DeletePersonalData.PasswordRequired")" />
                        </FormField>

                        <RadzenText TextStyle="TextStyle.Body2" class="rz-color-danger">
                            @T("DeletePersonalData.WarningText")
                        </RadzenText>

                    </RadzenStack>

                    <div class="ag-card-actions">
                        <RadzenButton Text="@T("DeletePersonalData.CancelButton")"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click=@(() => NavigationManager.NavigateTo("/Account/Manage/Profile")) />

                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="@T("DeletePersonalData.SubmitButton")"
                                      ButtonStyle="ButtonStyle.Danger"
                                      IsBusy="@_isDeleting"
                                      BusyText="@T("DeletePersonalData.DeletingBusyText")"
                                      Disabled="@_isDeleting" />
                    </div>

                </RadzenStack>
            </RadzenTemplateForm>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private InputModel Model { get; set; } = new();
    private User? _currentUser;
    private bool _isDeleting;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = await UserManager.GetUserAsync(authState.User);

        if (_currentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("DeletePersonalData.ErrorTitle"), T("DeletePersonalData.UnableToLoadProfileDetail"));
            NavigationManager.NavigateTo("/Account/Manage/Profile");
        }
    }

    private async Task OnValidSubmit(InputModel model)
    {
        if (_currentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("DeletePersonalData.ErrorTitle"), T("DeletePersonalData.UserNotLoadedDetail"));
            return;
        }

        // Zweifache Absicherung über Dialog
        var confirm = await Confirm.ConfirmAsync(
            T("DeletePersonalData.ConfirmMessage"),
            T("DeletePersonalData.ConfirmTitle"),
            okText: T("DeletePersonalData.ConfirmOk"),
            cancelText: T("DeletePersonalData.ConfirmCancel"));

        if (!confirm)
        {
            NotificationService.Notify(NotificationSeverity.Info, T("DeletePersonalData.CancelledTitle"), T("DeletePersonalData.CancelledDetail"));
            return;
        }

        _isDeleting = true;
        StateHasChanged();

        try
        {
            // Passwort prüfen
            if (!await UserManager.CheckPasswordAsync(_currentUser, model.Password))
            {
                NotificationService.Notify(NotificationSeverity.Error, T("DeletePersonalData.ErrorTitle"), T("DeletePersonalData.WrongPasswordDetail"));
                return;
            }

            var userId = await UserManager.GetUserIdAsync(_currentUser);
            var result = await UserManager.DeleteAsync(_currentUser);

            if (!result.Succeeded)
            {
                var errors = string.Join(" ", result.Errors.Select(e => e.Description));
                NotificationService.Notify(NotificationSeverity.Error, T("DeletePersonalData.DeletionFailedTitle"), errors);
                Logger.LogWarning("Failed to delete user {UserId}: {Errors}", userId, errors);
                return;
            }

            Logger.LogInformation("User {UserId} deleted their account.", userId);

            // Sign out via GET endpoint (SignOutAsync writes cookies — must run in real HTTP context)
            NavigationManager.NavigateTo("/Account/SignOutAndRedirect", forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error while deleting user {UserId}", await UserManager.GetUserIdAsync(_currentUser));
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("DeletePersonalData.CriticalErrorTitle"),
                T("DeletePersonalData.CriticalErrorDetail")
            );
        }
        finally
        {
            _isDeleting = false;
            StateHasChanged();
        }
    }

    // Validation lives in the markup as Radzen validator components. RadzenTemplateForm
    // (wrapped by CardForm) does not evaluate DataAnnotations and no DataAnnotationsValidator
    // is present, so attributes here would never run — they were removed rather than
    // translated into a second, silently-dead set of messages (#114).
    private sealed class InputModel
    {
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";
    }

}
