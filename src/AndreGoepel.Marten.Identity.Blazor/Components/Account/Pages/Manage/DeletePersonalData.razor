@page "/Account/Manage/DeletePersonalData"
@rendermode InteractiveServer

@using AndreGoepel.Marten.Identity.Users
@using Microsoft.AspNetCore.Identity

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject ILogger<DeletePersonalData> Logger
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager
@inject DialogService DialogService

<IdentityPageTitle Title="Delete Account" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Delete Account</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Deactivate your account and schedule your personal data for permanent erasure</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <!-- Starke Warnung -->
            <RadzenAlert AlertStyle="AlertStyle.Danger"
                         AllowClose="false"
                         Icon="warning"
                         Title="Your data will be permanently erased.">
                    Your account is deactivated immediately and you are signed out. Your personal data is then <strong>permanently erased</strong> once the retention period elapses, after which it cannot be recovered. Until then, an administrator can still reverse the deletion.
            </RadzenAlert>

            <RadzenTemplateForm TItem="InputModel"
                                Data="@Model"
                                Submit="@OnValidSubmit">
                <RadzenStack Gap="2rem">

                    <RadzenFieldset Text="Confirmation">
                        <RadzenStack Gap="1.5rem">

                            <RadzenFormField Text="Enter your current password to confirm deletion" Style="width: 100%;">
                                <ChildContent>
                                    <RadzenPassword @bind-Value="@Model.Password"
                                                    Name="Password"
                                                    Placeholder="Enter your password to confirm"
                                                    Style="width:100%" />
                                </ChildContent>
                                <Helper>
                                    <RadzenRequiredValidator Component="Password" Text="Password is required to confirm deletion" />
                                </Helper>
                            </RadzenFormField>

                            <RadzenText TextStyle="TextStyle.Body2" class="rz-color-danger">
                                After successful verification your account is deactivated immediately and your personal data is permanently erased once the retention period elapses.
                            </RadzenText>

                        </RadzenStack>
                    </RadzenFieldset>

                    <!-- Action Buttons -->
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 Gap="1rem"
                                 JustifyContent="JustifyContent.Center"
                                 Wrap="FlexWrap.Wrap">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="Permanently Delete My Account"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Large"
                                      IsBusy="@isDeleting"
                                      BusyText="Deleting account..."
                                      Disabled="@isDeleting" />

                        <RadzenButton Text="Cancel – Keep my account"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Size="ButtonSize.Large"
                                      Click=@(() => NavigationManager.NavigateTo("/Account/Manage/Profile")) />
                    </RadzenStack>

                </RadzenStack>
            </RadzenTemplateForm>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private InputModel Model { get; set; } = new();
    private User? CurrentUser;
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CurrentUser = await UserManager.GetUserAsync(authState.User);

        if (CurrentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Unable to load user profile.");
            NavigationManager.NavigateTo("/Account/Manage/Profile");
        }
    }

    private async Task OnValidSubmit(InputModel model)
    {
        if (CurrentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "User not loaded.");
            return;
        }

        // Zweifache Absicherung über Dialog
        var confirm = await DialogService.Confirm(
            "Your account will be deactivated now and your personal data permanently erased after the retention period. Continue?",
            "Final Confirmation",
            new ConfirmOptions { OkButtonText = "Yes, Delete My Account", CancelButtonText = "No, Cancel" });

        if (confirm != true)
        {
            NotificationService.Notify(NotificationSeverity.Info, "Cancelled", "Account deletion cancelled.");
            return;
        }

        isDeleting = true;
        StateHasChanged();

        try
        {
            // Passwort prüfen
            if (!await UserManager.CheckPasswordAsync(CurrentUser, model.Password))
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "The password you entered is incorrect.");
                return;
            }

            var userId = await UserManager.GetUserIdAsync(CurrentUser);
            var result = await UserManager.DeleteAsync(CurrentUser);

            if (!result.Succeeded)
            {
                var errors = string.Join(" ", result.Errors.Select(e => e.Description));
                NotificationService.Notify(NotificationSeverity.Error, "Deletion failed", errors);
                Logger.LogWarning("Failed to delete user {UserId}: {Errors}", userId, errors);
                return;
            }

            Logger.LogInformation("User {UserId} deleted their account.", userId);

            // Sign out via GET endpoint (SignOutAsync writes cookies — must run in real HTTP context)
            NavigationManager.NavigateTo("/Account/SignOutAndRedirect", forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error while deleting user {UserId}", await UserManager.GetUserIdAsync(CurrentUser));
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Critical Error",
                "An unexpected error occurred during account deletion. The process was aborted."
            );
        }
        finally
        {
            isDeleting = false;
            StateHasChanged();
        }
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Password is required to confirm deletion")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";
    }
}