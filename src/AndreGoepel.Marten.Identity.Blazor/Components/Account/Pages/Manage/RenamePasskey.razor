@page "/Account/Manage/Passkeys/Rename/{Id}"
@rendermode InteractiveServer

@using System.Buffers.Text

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<IdentityPageTitle Title="Rename Passkey" Breadcrumb="Account / Passkeys" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@(_passkey?.Name?.Length > 0 ? "Rename Passkey" : "Name Your New Passkey")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Choose a recognizable name for this security key</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            @if (_isLoading)
            {
                <div class="text-center my-8">
                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 240px;" />
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-muted mt-4">
                        Loading passkey information...
                    </RadzenText>
                </div>
            }
            else if (_hasError || _passkey is null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" Icon="error">
                    @(_errorMessage ?? "Passkey not found or session expired.")
                </RadzenAlert>
            }
            else
            {
                <RadzenTemplateForm TItem="RenamePasskeyModel"
                                    Data=@_model
                                    Submit=@OnValidSubmit>
                    <RadzenStack Gap="2rem">

                        <RadzenStack Gap="0.4rem">
                            <RadzenLabel Text="Passkey name" Component="NameField" />
                            <RadzenTextBox @bind-Value="_model.Name"
                                           Name="NameField"
                                           Placeholder="e.g. My iPhone 15, Work Laptop Key, Blue YubiKey"
                                           Style="width: 100%;" />
                            <RadzenRequiredValidator Component="NameField" Text="Name is required" />
                            <RadzenLengthValidator Component="NameField" Min="3" Max="100" Text="Name must be 3–100 characters long" />
                        </RadzenStack>

                        <div class="af-card-actions">
                            <RadzenButton Text="Cancel"
                                          ButtonStyle="ButtonStyle.Light"
                                          Disabled="@_isSaving"
                                          Click=@(() => NavigationManager.NavigateTo("/Account/Manage/Passkeys")) />

                            <RadzenButton ButtonType="ButtonType.Submit"
                                          Text="Save name"
                                          ButtonStyle="ButtonStyle.Primary"
                                          IsBusy="@_isSaving"
                                          BusyText="Saving..." />
                        </div>

                    </RadzenStack>
                </RadzenTemplateForm>
            }

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private RenamePasskeyModel _model = new();
    private UserPasskeyInfo? _passkey;
    private bool _hasError;
    private string? _errorMessage;
    private bool _isLoading = true;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Id))
        {
            _hasError = true;
            _errorMessage = "Missing passkey identifier.";
            _isLoading = false;
            return;
        }

        byte[] credentialId;
        try
        {
            credentialId = Base64Url.DecodeFromChars(Id);
        }
        catch (FormatException)
        {
            _hasError = true;
            _errorMessage = "Invalid passkey identifier format.";
            _isLoading = false;
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null)
        {
            _hasError = true;
            _errorMessage = "Cannot load user profile. Please sign in again.";
            NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
            _isLoading = false;
            return;
        }

        _passkey = await UserManager.GetPasskeyAsync(user, credentialId);

        if (_passkey is null)
        {
            _hasError = true;
            _errorMessage = "This passkey could not be found.";
            _isLoading = false;
            return;
        }

        _model.Name = _passkey.Name ?? "";
        _isLoading = false;
    }

    private async Task OnValidSubmit(RenamePasskeyModel input)
    {
        if (_passkey is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Passkey not loaded.");
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrWhiteSpace(input.Name))
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "Name is required.");
                return;
            }

            _passkey.Name = input.Name.Trim();

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);

            if (user is null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "User session expired.");
                NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            var result = await UserManager.AddOrUpdatePasskeyAsync(user, _passkey);

            if (result.Succeeded)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Success",
                    "Passkey name saved successfully."
                );
                NavigationManager.NavigateTo("/Account/Manage/Passkeys");
            }
            else
            {
                var msg = result.Errors.FirstOrDefault()?.Description
                       ?? "Failed to update passkey name.";
                NotificationService.Notify(NotificationSeverity.Error, "Error", msg);
            }
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private sealed class RenamePasskeyModel
    {
        [Required(ErrorMessage = "Name is required")]
        [StringLength(100, MinimumLength = 3,
            ErrorMessage = "Name must be between 3 and 100 characters.")]
        public string Name { get; set; } = "";
    }
}