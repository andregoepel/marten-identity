@page "/Account/Manage/Passkeys/Rename/{Id}"
@rendermode InteractiveServer

@using System.Buffers.Text
@using AndreGoepel.Marten.Identity.Users
@using Microsoft.AspNetCore.Identity

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<IdentityPageTitle Title="Rename Passkey" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@(passkey?.Name?.Length > 0 ? "Rename Passkey" : "Name Your New Passkey")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Choose a recognizable name for this security key</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            @if (isLoading)
            {
                <div class="text-center my-8">
                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 240px;" />
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-muted mt-4">
                        Loading passkey information...
                    </RadzenText>
                </div>
            }
            else if (hasError || passkey is null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" Icon="error">
                    @(errorMessage ?? "Passkey not found or session expired.")
                </RadzenAlert>
            }
            else
            {
                <RadzenTemplateForm TItem="RenamePasskeyModel"
                                    Data=@model
                                    Submit=@OnValidSubmit>
                    <RadzenStack Gap="2rem">

                        <RadzenFormField Text="Passkey name *" Style="width: 100%;">
                            <ChildContent>
                                <RadzenTextBox @bind-Value="model.Name"
                                               Name="NameField"
                                               Placeholder="e.g. My iPhone 15, Work Laptop Key, Blue YubiKey"
                                               Style="width: 100%;" />
                            </ChildContent>
                            <Helper>
                                <RadzenRequiredValidator Component="NameField" Text="Name is required" />
                                <RadzenLengthValidator Component="NameField" Min="3" Max="100" Text="Name must be 3–100 characters long" />
                            </Helper>
                        </RadzenFormField>

                        <RadzenStack Orientation="Orientation.Horizontal"
                                     Gap="1rem"
                                     JustifyContent="JustifyContent.Center"
                                     Wrap="FlexWrap.Wrap">
                            <RadzenButton ButtonType="ButtonType.Submit"
                                          Text="Save Name"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Size="ButtonSize.Large"
                                          IsBusy="@isSaving"
                                          BusyText="Saving..." />

                            <RadzenButton Text="Cancel"
                                          ButtonStyle="ButtonStyle.Secondary"
                                          Size="ButtonSize.Large"
                                          Disabled="@isSaving"
                                          Click=@(() => NavigationManager.NavigateTo("/Account/Manage/Passkeys")) />
                        </RadzenStack>

                    </RadzenStack>
                </RadzenTemplateForm>
            }

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private RenamePasskeyModel model = new();
    private UserPasskeyInfo? passkey;
    private bool hasError;
    private string? errorMessage;
    private bool isLoading = true;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Id))
        {
            hasError = true;
            errorMessage = "Missing passkey identifier.";
            isLoading = false;
            return;
        }

        byte[] credentialId;
        try
        {
            credentialId = Base64Url.DecodeFromChars(Id);
        }
        catch (FormatException)
        {
            hasError = true;
            errorMessage = "Invalid passkey identifier format.";
            isLoading = false;
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null)
        {
            hasError = true;
            errorMessage = "Cannot load user profile. Please sign in again.";
            NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
            isLoading = false;
            return;
        }

        passkey = await UserManager.GetPasskeyAsync(user, credentialId);

        if (passkey is null)
        {
            hasError = true;
            errorMessage = "This passkey could not be found.";
            isLoading = false;
            return;
        }

        model.Name = passkey.Name ?? "";
        isLoading = false;
    }

    private async Task OnValidSubmit(RenamePasskeyModel input)
    {
        if (passkey is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Passkey not loaded.");
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrWhiteSpace(input.Name))
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "Name is required.");
                return;
            }

            passkey.Name = input.Name.Trim();

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);

            if (user is null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "User session expired.");
                NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            var result = await UserManager.AddOrUpdatePasskeyAsync(user, passkey);

            if (result.Succeeded)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Success",
                    "Passkey name saved successfully."
                );
                NavigationManager.NavigateTo("/Account/Manage/Passkeys");
            }
            else
            {
                var msg = result.Errors.FirstOrDefault()?.Description
                       ?? "Failed to update passkey name.";
                NotificationService.Notify(NotificationSeverity.Error, "Error", msg);
            }
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private sealed class RenamePasskeyModel
    {
        [Required(ErrorMessage = "Name is required")]
        [StringLength(100, MinimumLength = 3,
            ErrorMessage = "Name must be between 3 and 100 characters.")]
        public string Name { get; set; } = "";
    }
}