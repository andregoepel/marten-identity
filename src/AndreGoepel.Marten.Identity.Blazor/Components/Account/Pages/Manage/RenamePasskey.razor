@page "/Account/Manage/Passkeys/Rename/{Id}"
@rendermode InteractiveServer
@inherits LocalizedComponentBase

@using System.Buffers.Text

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<AppPageTitle Title="@T("RenamePasskey.PageTitle")" Breadcrumb="@T("RenamePasskey.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@(_passkey?.Name?.Length > 0 ? T("RenamePasskey.RenameHeading") : T("RenamePasskey.NameNewHeading"))"
                    Subtitle="@T("RenamePasskey.Subtitle")" />

        @if (_isLoading)
        {
            <RadzenCard>
                <div class="text-center my-8">
                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 240px;" />
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-muted mt-4">
                        @T("RenamePasskey.LoadingText")
                    </RadzenText>
                </div>
            </RadzenCard>
        }
        else if (_hasError || _passkey is null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" Icon="error">
                @(_errorMessage ?? T("RenamePasskey.NotFoundOrExpired"))
            </RadzenAlert>
        }
        else
        {
            <CardForm TItem="RenamePasskeyModel"
                      Data="@_model"
                      Submit="@OnValidSubmit"
                      Cancel="@(() => NavigationManager.NavigateTo("/Account/Manage/Passkeys"))"
                      SubmitText="@T("RenamePasskey.SaveButton")"
                      IsBusy="@_isSaving">
                <FormField Label="@T("RenamePasskey.NameLabel")" For="NameField">
                    <RadzenTextBox @bind-Value="_model.Name"
                                   Name="NameField"
                                   Placeholder="@T("RenamePasskey.NamePlaceholder")"
                                   Style="width: 100%;" />
                    <RadzenRequiredValidator Component="NameField" Text="@T("RenamePasskey.NameRequired")" />
                    <RadzenLengthValidator Component="NameField" Min="3" Max="100" Text="@T("RenamePasskey.NameLength")" />
                </FormField>
            </CardForm>
        }

    </RadzenStack>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private RenamePasskeyModel _model = new();
    private UserPasskeyInfo? _passkey;
    private bool _hasError;
    private string? _errorMessage;
    private bool _isLoading = true;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Id))
        {
            _hasError = true;
            _errorMessage = T("RenamePasskey.MissingIdentifierError");
            _isLoading = false;
            return;
        }

        byte[] credentialId;
        try
        {
            credentialId = Base64Url.DecodeFromChars(Id);
        }
        catch (FormatException)
        {
            _hasError = true;
            _errorMessage = T("RenamePasskey.InvalidFormatError");
            _isLoading = false;
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null)
        {
            _hasError = true;
            _errorMessage = T("RenamePasskey.CannotLoadProfileError");
            NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
            _isLoading = false;
            return;
        }

        _passkey = await UserManager.GetPasskeyAsync(user, credentialId);

        if (_passkey is null)
        {
            _hasError = true;
            _errorMessage = T("RenamePasskey.NotFoundError");
            _isLoading = false;
            return;
        }

        _model.Name = _passkey.Name ?? "";
        _isLoading = false;
    }

    private async Task OnValidSubmit(RenamePasskeyModel input)
    {
        if (_passkey is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("RenamePasskey.ErrorTitle"), T("RenamePasskey.PasskeyNotLoadedDetail"));
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrWhiteSpace(input.Name))
            {
                NotificationService.Notify(NotificationSeverity.Error, T("RenamePasskey.ErrorTitle"), T("RenamePasskey.NameRequiredDetail"));
                return;
            }

            _passkey.Name = input.Name.Trim();

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);

            if (user is null)
            {
                NotificationService.Notify(NotificationSeverity.Error, T("RenamePasskey.ErrorTitle"), T("RenamePasskey.SessionExpiredDetail"));
                NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            var result = await UserManager.AddOrUpdatePasskeyAsync(user, _passkey);

            if (result.Succeeded)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    T("RenamePasskey.SuccessTitle"),
                    T("RenamePasskey.SavedDetail")
                );
                NavigationManager.NavigateTo("/Account/Manage/Passkeys");
            }
            else
            {
                var msg = result.Errors.FirstOrDefault()?.Description
                       ?? T("RenamePasskey.UpdateFailedDefaultDetail");
                NotificationService.Notify(NotificationSeverity.Error, T("RenamePasskey.ErrorTitle"), msg);
            }
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    // Validation lives in the markup as Radzen validator components. RadzenTemplateForm
    // (wrapped by CardForm) does not evaluate DataAnnotations and no DataAnnotationsValidator
    // is present, so attributes here would never run — they were removed rather than
    // translated into a second, silently-dead set of messages (#114).
    private sealed class RenamePasskeyModel
    {
        public string Name { get; set; } = "";
    }

}
