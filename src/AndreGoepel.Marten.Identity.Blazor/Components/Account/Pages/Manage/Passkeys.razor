@page "/Account/Manage/Passkeys"
@rendermode InteractiveServer

@using System.Buffers.Text

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

<IdentityPageTitle Title="Manage Passkeys" Breadcrumb="Account / Passkeys" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div class="ag-page-head">
            <div>
                <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Manage Passkeys</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Add, rename or remove your security keys (WebAuthn / passkeys)</RadzenText>
            </div>
            @if (!_isLoading && (_currentPasskeys?.Count ?? 0) < MaxPasskeyCount)
            {
                <RadzenButton Text="Register passkey"
                              ButtonStyle="ButtonStyle.Primary"
                              Icon="add"
                              Disabled="@_isLoading"
                              Click="@AddNewPasskey" />
            }
        </div>

        @if (_currentPasskeys?.Count >= MaxPasskeyCount)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" Icon="block">
                You have reached the maximum number of passkeys (@MaxPasskeyCount).
                Delete one before adding a new one.
            </RadzenAlert>
        }

        @if (_isLoading)
        {
            <RadzenCard>
                <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </RadzenCard>
        }
        else if (_currentPasskeys?.Count > 0)
        {
            <RadzenCard Style="padding: 0; overflow: hidden;">
                <RadzenDataGrid Data="@_currentPasskeys"
                                AllowPaging="true"
                                PageSize="8"
                                PagerHorizontalAlign="HorizontalAlign.Left"
                                ShowPagingSummary="true"
                                Density="Density.Compact"
                                Style="width: 100%;">
                    <Columns>
                        <RadzenDataGridColumn Property="@nameof(UserPasskeyInfo.Name)"
                                              Title="Passkey name"
                                              Width="280px" />

                        <RadzenDataGridColumn Property="@nameof(UserPasskeyInfo.CreatedAt)"
                                              Title="Registered"
                                              FormatString="{0:MMM dd, yyyy}"
                                              Width="140px" />

                        <RadzenDataGridColumn Title="Actions"
                                              Sortable="false"
                                              Filterable="false"
                                              Width="220px">
                            <Template Context="data">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                    <RadzenButton Text="Rename"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => RenamePasskey(data))" />

                                    <RadzenButton Text="Delete"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => DeletePasskey(data))" />
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }
        else
        {
            <div class="ag-empty">
                <span class="ag-empty-icon">🔑&#xFE0E;</span>
                <span class="ag-empty-title">No passkeys registered yet</span>
                <span class="ag-empty-text">Passkeys let you sign in without a password, using your device.</span>
            </div>
        }

    </RadzenStack>
</div>

@code {
    private const int MaxPasskeyCount = 100;

    private User? _currentUser;
    private IList<UserPasskeyInfo>? _currentPasskeys;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _currentUser = await UserManager.GetUserAsync(authState.User);

            if (_currentUser == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "Could not load user profile.");
                NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            _currentPasskeys = await UserManager.GetPasskeysAsync(_currentUser);
        }
        catch (Exception)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Failed to load passkeys.");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void AddNewPasskey()
    {
        NavigationManager.NavigateTo("/Account/Manage/Passkeys/Create");
    }

    private async Task RenamePasskey(UserPasskeyInfo passkey)
    {
        if (passkey?.CredentialId == null) return;

        var credentialIdBase64 = Base64Url.EncodeToString(passkey.CredentialId);
        NavigationManager.NavigateTo($"/Account/Manage/Passkeys/Rename/{credentialIdBase64}");
    }

    private async Task DeletePasskey(UserPasskeyInfo passkey)
    {
        if (_currentUser == null || passkey?.CredentialId == null) return;

        var confirmed = await DialogService.Confirm(
            $"Delete passkey **{passkey.Name}**?\n\nThis cannot be undone.",
            "Delete Passkey",
            new ConfirmOptions
            {
                OkButtonText = "Delete",
                CancelButtonText = "Cancel"
            });

        if (confirmed != true) return;

        try
        {
            var result = await UserManager.RemovePasskeyAsync(_currentUser, passkey.CredentialId);

            if (result.Succeeded)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Success", "Passkey deleted.");
                _currentPasskeys = await UserManager.GetPasskeysAsync(_currentUser);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error",
                    result.Errors.FirstOrDefault()?.Description ?? "Could not delete passkey.");
            }
        }
        catch (Exception)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "An unexpected error occurred.");
        }
    }
}