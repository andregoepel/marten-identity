@page "/Account/Manage/Passkeys"
@rendermode InteractiveServer
@inherits IdentityLocalizedComponentBase

@using System.Buffers.Text

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject ConfirmService Confirm
@inject NotificationService NotificationService

<AppPageTitle Title="@T("Passkeys.PageTitle")" Breadcrumb="@T("Passkeys.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("Passkeys.Heading")"
                    Subtitle="@T("Passkeys.Subtitle")">
            <Actions>
                @if (!_isLoading && (_currentPasskeys?.Count ?? 0) < MaxPasskeyCount)
                {
                    <RadzenButton Text="@T("Passkeys.RegisterButton")"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Icon="add"
                                  Disabled="@_isLoading"
                                  Click="@AddNewPasskey" />
                }
            </Actions>
        </PageHeader>

        @if (_currentPasskeys?.Count >= MaxPasskeyCount)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" Icon="block">
                @T("Passkeys.MaxReachedAlert", MaxPasskeyCount)
            </RadzenAlert>
        }

        @if (_isLoading)
        {
            <RadzenCard>
                <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </RadzenCard>
        }
        else if (_currentPasskeys?.Count > 0)
        {
            <DataCard>
                <RadzenDataGrid Data="@_currentPasskeys"
                                AllowPaging="true"
                                PageSize="8"
                                PagerHorizontalAlign="HorizontalAlign.Left"
                                ShowPagingSummary="true"
                                Density="Density.Compact"
                                Style="width: 100%;">
                    <Columns>
                        <RadzenDataGridColumn Property="@nameof(UserPasskeyInfo.Name)"
                                              Title="@T("Passkeys.ColumnPasskeyName")"
                                              Width="280px" />

                        <RadzenDataGridColumn Property="@nameof(UserPasskeyInfo.CreatedAt)"
                                              Title="@T("Passkeys.ColumnRegistered")"
                                              FormatString="{0:MMM dd, yyyy}"
                                              Width="140px" />

                        <RadzenDataGridColumn Title="@T("Passkeys.ColumnActions")"
                                              Sortable="false"
                                              Filterable="false"
                                              Width="220px"
                                              TextAlign="TextAlign.Right">
                            <Template Context="data">
                                <RowActions>
                                    <RadzenButton Text="@T("Passkeys.RenameButton")"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => RenamePasskey(data))" />

                                    <RadzenButton Text="@T("Passkeys.DeleteButton")"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => DeletePasskey(data))" />
                                </RowActions>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </DataCard>
        }
        else
        {
            <EmptyState Icon="@("\U0001F511︎")"
                        Title="@T("Passkeys.EmptyTitle")"
                        Text="@T("Passkeys.EmptyText")" />
        }

    </RadzenStack>
</div>

@code {
    private const int MaxPasskeyCount = 100;

    private User? _currentUser;
    private IList<UserPasskeyInfo>? _currentPasskeys;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _currentUser = await UserManager.GetUserAsync(authState.User);

            if (_currentUser == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, T("Passkeys.ErrorTitle"), T("Passkeys.UserNotFoundDetail"));
                NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            _currentPasskeys = await UserManager.GetPasskeysAsync(_currentUser);
        }
        catch (Exception)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("Passkeys.ErrorTitle"), T("Passkeys.LoadFailedDetail"));
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void AddNewPasskey()
    {
        NavigationManager.NavigateTo("/Account/Manage/Passkeys/Create");
    }

    private async Task RenamePasskey(UserPasskeyInfo passkey)
    {
        if (passkey?.CredentialId == null) return;

        var credentialIdBase64 = Base64Url.EncodeToString(passkey.CredentialId);
        NavigationManager.NavigateTo($"/Account/Manage/Passkeys/Rename/{credentialIdBase64}");
    }

    private async Task DeletePasskey(UserPasskeyInfo passkey)
    {
        if (_currentUser == null || passkey?.CredentialId == null) return;

        var confirmed = await Confirm.ConfirmDeleteAsync(
            T("Passkeys.DeleteConfirmItem", passkey.Name!), title: T("Passkeys.DeleteConfirmTitle"));

        if (!confirmed) return;

        try
        {
            var result = await UserManager.RemovePasskeyAsync(_currentUser, passkey.CredentialId);

            if (result.Succeeded)
            {
                NotificationService.Notify(NotificationSeverity.Success, T("Passkeys.SuccessTitle"), T("Passkeys.DeletedDetail"));
                _currentPasskeys = await UserManager.GetPasskeysAsync(_currentUser);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, T("Passkeys.ErrorTitle"),
                    result.Errors.FirstOrDefault()?.Description ?? T("Passkeys.DeleteFailedDefaultDetail"));
            }
        }
        catch (Exception)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("Passkeys.ErrorTitle"), T("Passkeys.UnexpectedErrorDetail"));
        }
    }

}
