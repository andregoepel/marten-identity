@page "/Account/Manage/PersonalData"
@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Personal Data – nerdventures.blog</PageTitle>

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Personal Data</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Download or delete the personal information associated with your account</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <!-- Erklärungstext -->
            <RadzenText TextStyle="TextStyle.Body1">
                This page lets you download a copy of all personal data we store about you
                (profile information, activity logs, etc.) or permanently delete your account
                and all related data.
            </RadzenText>

            <!-- Warnhinweis -->
            <RadzenAlert AlertStyle="AlertStyle.Danger"
                         AllowClose="false"
                         Icon="warning">
                <strong>Warning:</strong> Deleting your account deactivates it immediately and
                <strong>permanently erases your personal data once the retention period elapses</strong>
                — including all content, settings and history. After erasure this <strong>cannot be undone</strong>.
            </RadzenAlert>

            <!-- Action-Buttons -->
            <RadzenStack Orientation="Orientation.Horizontal"
                         Gap="1.5rem"
                         JustifyContent="JustifyContent.Center"
                         AlignItems="AlignItems.Center"
                         Wrap="FlexWrap.Wrap">

                <!-- Download (POST-Formular) -->
                <form action="/Account/Manage/DownloadPersonalData" method="post">
                    <AntiforgeryToken />
                    <RadzenButton ButtonType="ButtonType.Submit"
                                  Text="Download My Data"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Large"
                                  Icon="download" />
                </form>

                <!-- Delete-Link -->
                <RadzenButton Text="Delete My Account & All Data"
                              ButtonStyle="ButtonStyle.Danger"
                              Size="ButtonSize.Large"
                              Icon="delete_forever"
                              Click=@(() => NavigationManager.NavigateTo("/Account/Manage/DeletePersonalData")) />
            </RadzenStack>

            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-muted text-center mt-4">
                The downloaded file usually contains your data in JSON or ZIP format.
            </RadzenText>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
        {
            NavigationManager.NavigateTo("/Account/Login");
        }
    }
}