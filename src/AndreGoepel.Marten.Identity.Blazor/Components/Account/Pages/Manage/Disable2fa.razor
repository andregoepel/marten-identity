@page "/Account/Manage/Disable2fa"
@rendermode InteractiveServer

@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject ILogger<Disable2fa> Logger
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider

<AppPageTitle Title="Disable two-factor authentication (2FA)" Breadcrumb="Account / Two-factor authentication" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Disable two-factor authentication (2FA)</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Turn off 2FA for your account</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" Variant="Variant.Flat" Icon="warning">
                <strong>This action only disables 2FA.</strong><br />
                Disabling 2FA does <strong>not</strong> change the keys used in your authenticator apps.<br />
                If you want to change the authenticator key, please <a href="/Account/Manage/ResetAuthenticator">reset your authenticator keys</a> instead.
            </RadzenAlert>

            <RadzenStack Gap="1rem" AlignItems="AlignItems.Center">
                <RadzenButton Text="Disable 2FA"
                              ButtonStyle="ButtonStyle.Danger"
                              Size="ButtonSize.Large"
                              IsBusy="@_isProcessing"
                              BusyText="Disabling..."
                              Style="width: 100%; max-width: 360px;"
                              Click="@OnSubmitAsync" />
            </RadzenStack>

            <RadzenText TextStyle="TextStyle.Caption" class="text-center rz-color-muted">
                You can re-enable 2FA at any time from your security settings.
            </RadzenText>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private User? _user;
    private bool _isProcessing;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = await UserManager.GetUserAsync(authState.User);

        if (_user is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Could not load user profile.");
        }
    }

    private async Task OnSubmitAsync()
    {
        _isProcessing = true;
        StateHasChanged();

        try
        {
            if(_user == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "Invalid user.");
                return;
            }

            var result = await UserManager.SetTwoFactorEnabledAsync(_user, enabled: false);

            if (!result.Succeeded)
            {
                throw new InvalidOperationException("Failed to disable 2FA: " + string.Join(", ", result.Errors.Select(e => e.Description)));
            }

            var userId = await UserManager.GetUserIdAsync(_user);
            Logger.LogInformation("User {UserId} disabled 2FA", userId);

            NotificationService.Notify(NotificationSeverity.Info, "2FA has been disabled",
                "Two-factor authentication is now turned off. You can re-enable it anytime by setting up an authenticator app.");
            NavigationManager.NavigateTo("/Account/Manage/TwoFactorAuthentication");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to disable 2FA for user {UserId}", _user?.Id);
            NotificationService.Notify(
                NotificationSeverity.Error,
                summary: "Error",
                detail: "Could not disable 2FA. Please try again or contact support."
            );
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
