@page "/Account/Manage/Disable2fa"
@rendermode InteractiveServer
@inherits IdentityLocalizedComponentBase

@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject ILogger<Disable2fa> Logger
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider

<AppPageTitle Title="@T("Disable2fa.PageTitle")" Breadcrumb="@T("Disable2fa.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@T("Disable2fa.Heading")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">@T("Disable2fa.Subheading")</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" Variant="Variant.Flat" Icon="warning">
                <strong>@T("Disable2fa.AlertOnlyDisables")</strong><br />
                @T("Disable2fa.AlertKeysPrefix") <strong>@T("Disable2fa.AlertKeysStrong")</strong> @T("Disable2fa.AlertKeysSuffix")<br />
                @T("Disable2fa.AlertResetPrefix") <a href="/Account/Manage/ResetAuthenticator">@T("Disable2fa.AlertResetLinkText")</a> @T("Disable2fa.AlertResetSuffix")
            </RadzenAlert>

            <RadzenStack Gap="1rem" AlignItems="AlignItems.Center">
                <RadzenButton Text="@T("Disable2fa.SubmitButton")"
                              ButtonStyle="ButtonStyle.Danger"
                              Size="ButtonSize.Large"
                              IsBusy="@_isProcessing"
                              BusyText="@T("Disable2fa.DisablingBusyText")"
                              Style="width: 100%; max-width: 360px;"
                              Click="@OnSubmitAsync" />
            </RadzenStack>

            <RadzenText TextStyle="TextStyle.Caption" class="text-center rz-color-muted">
                @T("Disable2fa.FooterHint")
            </RadzenText>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private User? _user;
    private bool _isProcessing;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = await UserManager.GetUserAsync(authState.User);

        if (_user is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("Disable2fa.ErrorTitle"), T("Disable2fa.UserNotFoundDetail"));
        }
    }

    private async Task OnSubmitAsync()
    {
        _isProcessing = true;
        StateHasChanged();

        try
        {
            if(_user == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, T("Disable2fa.ErrorTitle"), T("Disable2fa.InvalidUserDetail"));
                return;
            }

            var result = await UserManager.SetTwoFactorEnabledAsync(_user, enabled: false);

            if (!result.Succeeded)
            {
                throw new InvalidOperationException("Failed to disable 2FA: " + string.Join(", ", result.Errors.Select(e => e.Description)));
            }

            var userId = await UserManager.GetUserIdAsync(_user);
            Logger.LogInformation("User {UserId} disabled 2FA", userId);

            NotificationService.Notify(NotificationSeverity.Info, T("Disable2fa.DisabledTitle"),
                T("Disable2fa.DisabledDetail"));
            NavigationManager.NavigateTo("/Account/Manage/TwoFactorAuthentication");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to disable 2FA for user {UserId}", _user?.Id);
            NotificationService.Notify(
                NotificationSeverity.Error,
                summary: T("Disable2fa.ErrorTitle"),
                detail: T("Disable2fa.DisableFailedDetail")
            );
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

}
