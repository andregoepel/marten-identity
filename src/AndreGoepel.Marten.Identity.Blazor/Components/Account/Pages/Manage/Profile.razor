@page "/Account/Manage/Profile"
@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NotificationService NotificationService

<IdentityPageTitle Title="Profile" Breadcrumb="Account / Profile" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Your Profile</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Update your personal information</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <RadzenTemplateForm TItem="ProfileModel"
                                Data="@Model"
                                Submit="@OnValidSubmit">
                <RadzenStack Gap="2rem">

                    <RadzenStack Gap="1.5rem">

                        <RadzenStack Gap="0.4rem">
                            <RadzenLabel Text="Username" Component="Username" />
                            <RadzenTextBox @bind-Value="@Model.UserName"
                                           Name="Username"
                                           ReadOnly="true"
                                           Style="width:100%; background-color: var(--rz-input-disabled-background);" />
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                Your unique identifier (cannot be changed)
                            </RadzenText>
                        </RadzenStack>

                        <RadzenStack Gap="0.4rem">
                            <RadzenLabel Text="Phone number" Component="PhoneNumber" />
                            <RadzenTextBox @bind-Value="@Model.PhoneNumber"
                                           Name="PhoneNumber"
                                           Placeholder="+49 123 4567890"
                                           Style="width:100%" />
                            <RadzenRequiredValidator Component="PhoneNumber"
                                                     Text="Phone number is required" />
                            <RadzenRegexValidator Component="PhoneNumber"
                                                  Text="Please enter a valid phone number"
                                                  Pattern="^\s*(?:\+?(\d{1,3}))?[-. (]*(\d{3})[-. )]*(\d{3})[-. ]*(\d{4})(?: *x(\d+))?\s*$" />
                        </RadzenStack>

                    </RadzenStack>

                    <div class="af-card-actions">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="Save changes"
                                      ButtonStyle="ButtonStyle.Primary"
                                      IsBusy="@_isSaving"
                                      BusyText="Saving..." />
                    </div>

                </RadzenStack>
            </RadzenTemplateForm>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private ProfileModel Model { get; set; } = new();
    private User? _currentUser;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = await UserManager.GetUserAsync(authState.User);

        if (_currentUser == null)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Error",
                "Could not load your profile. Please try again."
            );
            return;
        }

        Model.UserName = _currentUser.UserName;
        Model.PhoneNumber = _currentUser.PhoneNumber ?? "";
    }

    private async Task OnValidSubmit(ProfileModel model)
    {
        if (_currentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "No user loaded.");
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            bool hasChanges = false;

            // Phone number changed?
            if (model.PhoneNumber?.Trim() != _currentUser.PhoneNumber?.Trim())
            {
                var result = await UserManager.SetPhoneNumberAsync(_currentUser, model.PhoneNumber);
                if (!result.Succeeded)
                {
                    foreach (var error in result.Errors)
                    {
                        NotificationService.Notify(NotificationSeverity.Error, "Error", error.Description);
                    }
                    return;
                }
                hasChanges = true;
            }

            if (hasChanges)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Success",
                    "Your profile has been updated."
                );
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Info,
                    "Info",
                    "No changes were made."
                );
            }
        }
        catch (Exception)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Error",
                "An unexpected error occurred while saving."
            );
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private sealed class ProfileModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string? UserName { get; set; }

        [Phone(ErrorMessage = "Please enter a valid phone number")]
        public string? PhoneNumber { get; set; }
    }
}
