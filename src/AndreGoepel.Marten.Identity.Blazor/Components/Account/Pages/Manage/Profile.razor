@page "/Account/Manage/Profile"
@rendermode InteractiveServer
@inherits LocalizedComponentBase

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NotificationService NotificationService

<AppPageTitle Title="@T("Profile.PageTitle")" Breadcrumb="@T("Profile.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("Profile.Heading")" Subtitle="@T("Profile.Subtitle")" />

        <CardForm TItem="ProfileModel" Data="@Model" Submit="@OnValidSubmit" IsBusy="@_isSaving">
            <FormField Label="@T("Profile.UsernameLabel")" For="Username" Hint="@T("Profile.UsernameHint")">
                <RadzenTextBox @bind-Value="@Model.UserName"
                               Name="Username"
                               ReadOnly="true"
                               Style="width:100%; background-color: var(--rz-input-disabled-background);" />
            </FormField>

            <FormField Label="@T("Profile.PhoneLabel")" For="PhoneNumber">
                <RadzenTextBox @bind-Value="@Model.PhoneNumber"
                               Name="PhoneNumber"
                               Placeholder="+49 123 4567890"
                               Style="width:100%" />
                <RadzenRequiredValidator Component="PhoneNumber"
                                         Text="@T("Profile.PhoneRequired")" />
                <RadzenRegexValidator Component="PhoneNumber"
                                      Text="@T("Profile.PhoneInvalid")"
                                      Pattern="^\s*(?:\+?(\d{1,3}))?[-. (]*(\d{3})[-. )]*(\d{3})[-. ]*(\d{4})(?: *x(\d+))?\s*$" />
            </FormField>
        </CardForm>

    </RadzenStack>
</div>

@code {
    private ProfileModel Model { get; set; } = new();
    private User? _currentUser;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = await UserManager.GetUserAsync(authState.User);

        if (_currentUser == null)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("Profile.ErrorTitle"),
                T("Profile.UserNotFoundDetail")
            );
            return;
        }

        Model.UserName = _currentUser.UserName;
        Model.PhoneNumber = _currentUser.PhoneNumber ?? "";
    }

    private async Task OnValidSubmit(ProfileModel model)
    {
        if (_currentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("Profile.ErrorTitle"), T("Profile.UserNotLoadedDetail"));
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            bool hasChanges = false;

            // Phone number changed?
            if (model.PhoneNumber?.Trim() != _currentUser.PhoneNumber?.Trim())
            {
                var result = await UserManager.SetPhoneNumberAsync(_currentUser, model.PhoneNumber);
                if (!result.Succeeded)
                {
                    foreach (var error in result.Errors)
                    {
                        NotificationService.Notify(NotificationSeverity.Error, T("Profile.ErrorTitle"), error.Description);
                    }
                    return;
                }
                hasChanges = true;
            }

            if (hasChanges)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    T("Profile.SuccessTitle"),
                    T("Profile.SuccessDetail")
                );
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Info,
                    T("Profile.InfoTitle"),
                    T("Profile.NoChangesDetail")
                );
            }
        }
        catch (Exception)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("Profile.ErrorTitle"),
                T("Profile.UnexpectedErrorDetail")
            );
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    // Validation lives in the markup as Radzen validator components. RadzenTemplateForm
    // (wrapped by CardForm) does not evaluate DataAnnotations and no DataAnnotationsValidator
    // is present, so attributes here would never run — they were removed rather than
    // translated into a second, silently-dead set of messages (#114).
    private sealed class ProfileModel
    {
        // UserName is rendered read-only, so it cannot be emptied from the UI.
        public string? UserName { get; set; }

        public string? PhoneNumber { get; set; }
    }

}
