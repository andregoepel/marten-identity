@page "/Account/Manage/TwoFactorAuthentication"

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager

<IdentityPageTitle Title="Two-Factor Authentication" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Two-Factor Authentication (2FA)</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Add an extra layer of security to your account</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            @if (_is2FaEnabled)
            {
                <RadzenAlert AlertStyle="AlertStyle.Success" Icon="shield" AllowClose="false">
                    Two-factor authentication is <strong>currently enabled</strong>.
                </RadzenAlert>

                @if (_recoveryCodesLeft == 0)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Icon="error_outline">
                        <strong>You have no recovery codes left!</strong><br />
                        Generate a new set before you can use recovery codes to log in.
                        <div class="mt-4">
                            <RadzenButton Text="Generate New Recovery Codes"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Size="ButtonSize.Large"
                                          Click="@(() => NavigationManager.NavigateTo("/Account/Manage/GenerateRecoveryCodes"))" />
                        </div>
                    </RadzenAlert>
                }
                else if (_recoveryCodesLeft <= 3)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" Icon="warning">
                        <strong>@_recoveryCodesLeft recovery code@(_recoveryCodesLeft == 1 ? "" : "s") remaining</strong><br />
                        Consider generating a new set soon.
                        <div class="mt-4">
                            <RadzenButton Text="Generate New Recovery Codes"
                                          ButtonStyle="ButtonStyle.Warning"
                                          Size="ButtonSize.Large"
                                          Click="@(() => NavigationManager.NavigateTo("/Account/Manage/GenerateRecoveryCodes"))" />
                        </div>
                    </RadzenAlert>
                }

                <RadzenStack Orientation="Orientation.Horizontal"
                             Gap="1rem"
                             Wrap="FlexWrap.Wrap"
                             class="mt-8">
                    <LinkButton Text="Disable 2FA"
                                ButtonStyle="ButtonStyle.Danger"
                                Path="/Account/Manage/Disable2fa" />

                    <LinkButton Text="Reset Recovery Codes"
                                ButtonStyle="ButtonStyle.Warning"
                                Path="/Account/Manage/GenerateRecoveryCodes" />
                </RadzenStack>
            }
            else
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" Icon="info" AllowClose="false">
                    Two-factor authentication is currently <strong>disabled</strong>.
                </RadzenAlert>
            }

            <RadzenStack Gap="1.5rem" class="mt-8">
                <RadzenText TextStyle="TextStyle.Subtitle1">Authenticator app</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1">
                    Use a time-based one-time password (TOTP) app such as Google Authenticator,
                    Microsoft Authenticator, Authy, Bitwarden, 1Password, etc.
                </RadzenText>

                @if (!_hasAuthenticator)
                {
                    <LinkButton Text="Add Authenticator App"
                                ButtonStyle="ButtonStyle.Primary"
                                Path="/Account/Manage/EnableAuthenticator" />
                }
                else
                {
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
                        <LinkButton Text="Reconfigure Authenticator App"
                                    ButtonStyle="ButtonStyle.Primary"
                                    Path="/Account/Manage/EnableAuthenticator" />

                        <LinkButton Text="Reset Authenticator App"
                                    ButtonStyle="ButtonStyle.Danger"
                                    Path="/Account/Manage/ResetAuthenticator" />
                    </RadzenStack>
                }
            </RadzenStack>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private bool _hasAuthenticator;
    private int _recoveryCodesLeft;
    private bool _is2FaEnabled;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
        {
            NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
            return;
        }

        _hasAuthenticator = await UserManager.GetAuthenticatorKeyAsync(user) is not null;
        _is2FaEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
        _recoveryCodesLeft = await UserManager.CountRecoveryCodesAsync(user);
    }
}
