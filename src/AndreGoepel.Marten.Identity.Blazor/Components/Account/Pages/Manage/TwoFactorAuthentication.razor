@page "/Account/Manage/TwoFactorAuthentication"
@inherits LocalizedComponentBase

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager

<AppPageTitle Title="@T("TwoFactorAuthentication.PageTitle")" Breadcrumb="@T("TwoFactorAuthentication.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@T("TwoFactorAuthentication.Heading")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">@T("TwoFactorAuthentication.Subheading")</RadzenText>
        </div>

        @if (_is2FaEnabled)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" Icon="shield" AllowClose="false">
                @T("TwoFactorAuthentication.EnabledPrefix") <strong>@T("TwoFactorAuthentication.EnabledStrong")</strong>.
            </RadzenAlert>

            @if (_recoveryCodesLeft == 0)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Icon="error_outline" AllowClose="false">
                    <strong>@T("TwoFactorAuthentication.NoCodesStrong")</strong><br />
                    @T("TwoFactorAuthentication.NoCodesText")
                    <div class="mt-4">
                        <RadzenButton Text="@T("TwoFactorAuthentication.GenerateCodesButton")"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Click="@(() => NavigationManager.NavigateTo("/Account/Manage/GenerateRecoveryCodes"))" />
                    </div>
                </RadzenAlert>
            }
            else if (_recoveryCodesLeft <= 3)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Icon="warning" AllowClose="false">
                    <strong>@(_recoveryCodesLeft == 1
                        ? T("TwoFactorAuthentication.RecoveryCodesRemainingSingular", _recoveryCodesLeft)
                        : T("TwoFactorAuthentication.RecoveryCodesRemainingPlural", _recoveryCodesLeft))</strong><br />
                    @T("TwoFactorAuthentication.ConsiderGeneratingText")
                    <div class="mt-4">
                        <RadzenButton Text="@T("TwoFactorAuthentication.GenerateCodesButton")"
                                      ButtonStyle="ButtonStyle.Warning"
                                      Click="@(() => NavigationManager.NavigateTo("/Account/Manage/GenerateRecoveryCodes"))" />
                    </div>
                </RadzenAlert>
            }
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" Icon="warning" AllowClose="false">
                @T("TwoFactorAuthentication.DisabledPrefix") <strong>@T("TwoFactorAuthentication.DisabledStrong")</strong>.
            </RadzenAlert>
        }

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="1.5rem" AlignItems="AlignItems.Stretch">

            @if (_is2FaEnabled)
            {
                <div class="ag-actions-inline">
                    <LinkButton Text="@T("TwoFactorAuthentication.DisableButton")"
                                ButtonStyle="ButtonStyle.Danger"
                                Path="/Account/Manage/Disable2fa" />

                    <LinkButton Text="@T("TwoFactorAuthentication.ResetCodesButton")"
                                ButtonStyle="ButtonStyle.Warning"
                                Path="/Account/Manage/GenerateRecoveryCodes" />
                </div>
            }

            <RadzenStack Gap="1.5rem">
                <RadzenText TextStyle="TextStyle.Subtitle1">@T("TwoFactorAuthentication.AuthenticatorAppHeading")</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); line-height: 1.55;">
                    @T("TwoFactorAuthentication.AuthenticatorAppText")
                </RadzenText>

                @if (!_hasAuthenticator)
                {
                    <div class="ag-actions-inline">
                        <LinkButton Text="@T("TwoFactorAuthentication.AddAuthenticatorButton")"
                                    ButtonStyle="ButtonStyle.Primary"
                                    Path="/Account/Manage/EnableAuthenticator" />
                    </div>
                }
                else
                {
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
                        <LinkButton Text="@T("TwoFactorAuthentication.ReconfigureAuthenticatorButton")"
                                    ButtonStyle="ButtonStyle.Primary"
                                    Path="/Account/Manage/EnableAuthenticator" />

                        <LinkButton Text="@T("TwoFactorAuthentication.ResetAuthenticatorButton")"
                                    ButtonStyle="ButtonStyle.Danger"
                                    Path="/Account/Manage/ResetAuthenticator" />
                    </RadzenStack>
                }
            </RadzenStack>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private bool _hasAuthenticator;
    private int _recoveryCodesLeft;
    private bool _is2FaEnabled;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
        {
            NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
            return;
        }

        _hasAuthenticator = await UserManager.GetAuthenticatorKeyAsync(user) is not null;
        _is2FaEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
        _recoveryCodesLeft = await UserManager.CountRecoveryCodesAsync(user);
    }

}
