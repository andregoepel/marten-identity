@page "/Account/Manage/Email"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.WebUtilities

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject IEmailSender<User> EmailSender
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<IdentityPageTitle Title="Manage Email" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Manage Email</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Update or verify your email address</RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <RadzenTemplateForm TItem="ChangeEmailModel"
                                Data="@Model"
                                Submit="@OnValidSubmit">
                <RadzenStack Gap="2rem">

                    <RadzenFieldset Text="Current Email">
                        <RadzenStack Gap="1.25rem">

                            <RadzenFormField Text="Current email" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="@_currentEmail"
                                               Name="CurrentEmail"
                                               ReadOnly="true"
                                               Style="width:100%; background-color: var(--rz-input-disabled-background);" />
                            </RadzenFormField>

                            @if (!_isEmailConfirmed)
                            {
                                <div>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-warning">
                                        Your email is not yet confirmed.
                                    </RadzenText>
                                    <RadzenButton Text="Send verification email"
                                                  ButtonStyle="ButtonStyle.Warning"
                                                  Size="ButtonSize.Medium"
                                                  IsBusy=@_isSendingVerification
                                                  BusyText="Sending..."
                                                  Click=@SendVerificationEmail
                                                  Style="margin-top: 0.75rem;" />
                                </div>
                            }
                            else
                            {
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-success">
                                    Email confirmed ✓
                                </RadzenText>
                            }

                        </RadzenStack>
                    </RadzenFieldset>

                    <RadzenFieldset Text="Change Email Address">
                        <RadzenStack Gap="1.5rem">

                            <RadzenFormField Text="New email address *" Style="width: 100%;">
                                <ChildContent>
                                    <RadzenTextBox @bind-Value="@Model.NewEmail"
                                                   Name="NewEmail"
                                                   Placeholder="you@yourdomain.com"
                                                   AutoCompleteType="AutoCompleteType.Email"
                                                   Style="width:100%" />
                                </ChildContent>
                                <Helper>
                                    <RadzenRequiredValidator Component="NewEmail" Text="New email is required" />
                                    <RadzenEmailValidator Component="NewEmail" Text="Please enter a valid email address" />
                                    <RadzenCompareValidator Component="NewEmail" Value="@_currentEmail" Text="New email must be different from current email" Operator="CompareOperator.NotEqual" />
                                </Helper>
                            </RadzenFormField>

                        </RadzenStack>
                    </RadzenFieldset>

                    <!-- Action Buttons -->
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 Gap="1rem"
                                 JustifyContent="JustifyContent.Center"
                                 Wrap="FlexWrap.Wrap">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="Change Email"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Large"
                                      IsBusy="@_isChangingEmail"
                                      BusyText="Processing..." />

                        <RadzenButton Text="Cancel"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Large"
                                      Click=@(() => NavigationManager.NavigateTo("/Account/Manage/Profile")) />
                    </RadzenStack>

                </RadzenStack>
            </RadzenTemplateForm>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private ChangeEmailModel Model { get; set; } = new();
    private User? _currentUser;
    private string? _currentEmail;
    private bool _isEmailConfirmed;
    private bool _isSendingVerification;
    private bool _isChangingEmail;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = await UserManager.GetUserAsync(authState.User);

        if (_currentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Could not load user profile.");
            return;
        }

        _currentEmail = await UserManager.GetEmailAsync(_currentUser);
        _isEmailConfirmed = await UserManager.IsEmailConfirmedAsync(_currentUser);
        Model.NewEmail = _currentEmail;
    }

    private async Task OnValidSubmit(ChangeEmailModel model)
    {
        if (_currentUser == null || string.IsNullOrWhiteSpace(_currentEmail))
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "User not loaded.");
            return;
        }

        if (model.NewEmail?.Trim() == _currentEmail?.Trim())
        {
            NotificationService.Notify(NotificationSeverity.Info, "Info", "No email change detected.");
            return;
        }

        _isChangingEmail = true;
        StateHasChanged();

        try
        {
            var userId = await UserManager.GetUserIdAsync(_currentUser);
            var code = await UserManager.GenerateChangeEmailTokenAsync(_currentUser, model.NewEmail!);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));

            var callbackUrl = NavigationManager.GetUriWithQueryParameters(
                NavigationManager.ToAbsoluteUri("/Account/ConfirmEmailChange").AbsoluteUri,
                new Dictionary<string, object?>
                {
                    ["userId"] = userId,
                    ["email"] = model.NewEmail,
                    ["code"] = code
                });

            await EmailSender.SendConfirmationLinkAsync(
                _currentUser,
                model.NewEmail!,
                HtmlEncoder.Default.Encode(callbackUrl));

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Success",
                "A confirmation link has been sent to your new email address. Please check your inbox."
            );

            // Optional: zurück zur Profile-Seite
            // NavigationManager.NavigateTo("/Account/Manage/Profile");
        }
        catch (Exception)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Error",
                "Failed to send confirmation email. Please try again later."
            );
        }
        finally
        {
            _isChangingEmail = false;
            StateHasChanged();
        }
    }

    private async Task SendVerificationEmail()
    {
        if (_currentUser == null || string.IsNullOrWhiteSpace(_currentEmail))
            return;

        _isSendingVerification = true;
        StateHasChanged();

        try
        {
            var userId = await UserManager.GetUserIdAsync(_currentUser);
            var code = await UserManager.GenerateEmailConfirmationTokenAsync(_currentUser);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));

            var callbackUrl = NavigationManager.GetUriWithQueryParameters(
                NavigationManager.ToAbsoluteUri("/Account/ConfirmEmail").AbsoluteUri,
                new Dictionary<string, object?>
                {
                    ["userId"] = userId,
                    ["code"] = code
                });

            await EmailSender.SendConfirmationLinkAsync(
                _currentUser,
                _currentEmail,
                HtmlEncoder.Default.Encode(callbackUrl));

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Sent",
                "Verification email has been resent. Please check your inbox."
            );
        }
        catch
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Error",
                "Could not send verification email. Try again later."
            );
        }
        finally
        {
            _isSendingVerification = false;
            StateHasChanged();
        }
    }

    private sealed class ChangeEmailModel
    {
        [Required(ErrorMessage = "New email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string? NewEmail { get; set; }
    }
}
