@page "/Account/Manage/Email"
@rendermode InteractiveServer
@inherits IdentityLocalizedComponentBase
@using Microsoft.AspNetCore.WebUtilities

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject IEmailSender<User> EmailSender
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<AppPageTitle Title="@T("Email.PageTitle")" Breadcrumb="@T("Email.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("Email.Heading")" Subtitle="@T("Email.Subtitle")" />

        <CardForm TItem="ChangeEmailModel"
                  Data="@Model"
                  Submit="@OnValidSubmit"
                  Cancel="@(() => NavigationManager.NavigateTo("/Account/Manage/Profile"))"
                  SubmitText="@T("Email.Submit")"
                  BusyText="@T("Email.Processing")"
                  IsBusy="@_isChangingEmail">
            <FormField Label="@T("Email.CurrentEmailLabel")" For="CurrentEmail">
                <div style="display:flex; align-items:center; gap:12px;">
                    <RadzenTextBox @bind-Value="@_currentEmail"
                                   Name="CurrentEmail"
                                   ReadOnly="true"
                                   Style="flex:1; background-color: var(--rz-input-disabled-background);" />
                    @if (_isEmailConfirmed)
                    {
                        <span class="ag-badge ag-badge-success">@T("Email.ConfirmedBadge")</span>
                    }
                </div>
                @if (!_isEmailConfirmed)
                {
                    <div>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-color-warning">
                            @T("Email.NotConfirmedText")
                        </RadzenText>
                        <RadzenButton Text="@T("Email.SendVerificationButton")"
                                      ButtonStyle="ButtonStyle.Warning"
                                      Size="ButtonSize.Medium"
                                      IsBusy=@_isSendingVerification
                                      BusyText="@T("Email.SendingBusyText")"
                                      Click=@SendVerificationEmail
                                      Style="margin-top: 0.75rem;" />
                    </div>
                }
            </FormField>

            <FormField Label="@T("Email.NewEmailLabel")" For="NewEmail">
                <RadzenTextBox @bind-Value="@Model.NewEmail"
                               Name="NewEmail"
                               Placeholder="you@yourdomain.com"
                               AutoCompleteType="AutoCompleteType.Email"
                               Style="width:100%" />
                <RadzenRequiredValidator Component="NewEmail" Text="@T("Email.NewEmailRequired")" />
                <RadzenEmailValidator Component="NewEmail" Text="@T("Email.NewEmailInvalid")" />
                <RadzenCompareValidator Component="NewEmail" Value="@_currentEmail" Text="@T("Email.NewEmailSameAsCurrent")" Operator="CompareOperator.NotEqual" />
            </FormField>
        </CardForm>

    </RadzenStack>
</div>

@code {
    private ChangeEmailModel Model { get; set; } = new();
    private User? _currentUser;
    private string? _currentEmail;
    private bool _isEmailConfirmed;
    private bool _isSendingVerification;
    private bool _isChangingEmail;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = await UserManager.GetUserAsync(authState.User);

        if (_currentUser == null)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("Email.ErrorTitle"), T("Email.UserNotFoundDetail"));
            return;
        }

        _currentEmail = await UserManager.GetEmailAsync(_currentUser);
        _isEmailConfirmed = await UserManager.IsEmailConfirmedAsync(_currentUser);
        Model.NewEmail = _currentEmail;
    }

    private async Task OnValidSubmit(ChangeEmailModel model)
    {
        if (_currentUser == null || string.IsNullOrWhiteSpace(_currentEmail))
        {
            NotificationService.Notify(NotificationSeverity.Error, T("Email.ErrorTitle"), T("Email.UserNotLoadedDetail"));
            return;
        }

        if (model.NewEmail?.Trim() == _currentEmail?.Trim())
        {
            NotificationService.Notify(NotificationSeverity.Info, T("Email.InfoTitle"), T("Email.NoChangeDetail"));
            return;
        }

        _isChangingEmail = true;
        StateHasChanged();

        try
        {
            var userId = await UserManager.GetUserIdAsync(_currentUser);
            var code = await UserManager.GenerateChangeEmailTokenAsync(_currentUser, model.NewEmail!);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));

            var callbackUrl = NavigationManager.GetUriWithQueryParameters(
                NavigationManager.ToAbsoluteUri("/Account/ConfirmEmailChange").AbsoluteUri,
                new Dictionary<string, object?>
                {
                    ["userId"] = userId,
                    ["email"] = model.NewEmail,
                    ["code"] = code
                });

            await EmailSender.SendConfirmationLinkAsync(
                _currentUser,
                model.NewEmail!,
                HtmlEncoder.Default.Encode(callbackUrl));

            NotificationService.Notify(
                NotificationSeverity.Success,
                T("Email.SuccessTitle"),
                T("Email.ConfirmationSentDetail")
            );

            // Optional: zurück zur Profile-Seite
            // NavigationManager.NavigateTo("/Account/Manage/Profile");
        }
        catch (Exception)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("Email.ErrorTitle"),
                T("Email.SendFailedDetail")
            );
        }
        finally
        {
            _isChangingEmail = false;
            StateHasChanged();
        }
    }

    private async Task SendVerificationEmail()
    {
        if (_currentUser == null || string.IsNullOrWhiteSpace(_currentEmail))
            return;

        _isSendingVerification = true;
        StateHasChanged();

        try
        {
            var userId = await UserManager.GetUserIdAsync(_currentUser);
            var code = await UserManager.GenerateEmailConfirmationTokenAsync(_currentUser);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));

            var callbackUrl = NavigationManager.GetUriWithQueryParameters(
                NavigationManager.ToAbsoluteUri("/Account/ConfirmEmail").AbsoluteUri,
                new Dictionary<string, object?>
                {
                    ["userId"] = userId,
                    ["code"] = code
                });

            await EmailSender.SendConfirmationLinkAsync(
                _currentUser,
                _currentEmail,
                HtmlEncoder.Default.Encode(callbackUrl));

            NotificationService.Notify(
                NotificationSeverity.Success,
                T("Email.SentTitle"),
                T("Email.ResentDetail")
            );
        }
        catch
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("Email.ErrorTitle"),
                T("Email.VerificationSendFailedDetail")
            );
        }
        finally
        {
            _isSendingVerification = false;
            StateHasChanged();
        }
    }

    // Validation lives in the markup as Radzen validator components. RadzenTemplateForm
    // (wrapped by CardForm) does not evaluate DataAnnotations and no DataAnnotationsValidator
    // is present, so attributes here would never run — they were removed rather than
    // translated into a second, silently-dead set of messages (#114).
    private sealed class ChangeEmailModel
    {
        public string? NewEmail { get; set; }
    }

}
