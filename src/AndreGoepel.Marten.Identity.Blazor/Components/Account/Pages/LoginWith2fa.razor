@page "/Account/LoginWith2fa"
@attribute [AllowAnonymous]
@layout LoginLayout
@rendermode InteractiveServer
@inherits LocalizedComponentBase

@inject NotificationService NotificationService
@inject LoginTokenProtector LoginTokens

<AppPageTitle Title="@T("LoginWith2fa.PageTitle")" />

<div class="ag-login-head">
    <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4" Text="@T("LoginWith2fa.Heading")" />
    <RadzenText TextStyle="TextStyle.Body2" class="ag-login-sub" Text="@T("LoginWith2fa.Subheading")" />
</div>

<RadzenTemplateForm TItem="InputModel" Data="@Input" Submit="@OnSubmitAsync">
    <RadzenStack Gap="1.25rem">

        <FormField Label="@T("LoginWith2fa.CodeLabel")" For="TwoFactorCode">
            <RadzenTextBox @bind-Value="@Input.TwoFactorCode"
                           Name="TwoFactorCode"
                           Placeholder="@T("LoginWith2fa.CodePlaceholder")"
                           AutoCompleteType="AutoCompleteType.Off"
                           Style="width:100%" />
            <RadzenRequiredValidator Component="TwoFactorCode" Text="@T("LoginWith2fa.CodeRequired")" />
            <RadzenLengthValidator Component="TwoFactorCode" Min="6" Max="7"
                                   Text="@T("LoginWith2fa.CodeLength")" />
        </FormField>

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenCheckBox @bind-Value="@Input.RememberMachine" Name="RememberMachine" />
            <RadzenLabel Text="@T("LoginWith2fa.RememberMachine")" Component="RememberMachine" />
        </RadzenStack>

        <div class="ag-login-actions">
            <RadzenButton ButtonType="ButtonType.Submit"
                          Text="@T("LoginWith2fa.Submit")"
                          ButtonStyle="ButtonStyle.Primary"
                          IsBusy="@_isProcessing"
                          BusyText="@T("LoginWith2fa.Verifying")" />
        </div>

    </RadzenStack>
</RadzenTemplateForm>

<div class="ag-login-footer-links">
    <span class="ag-login-resend">
        <RadzenLink Path="@($"/Account/LoginWithRecoveryCode?returnUrl={ReturnUrl}")"
                    Text="@T("LoginWith2fa.UseRecoveryCode")" />
    </span>
</div>

<SignInHandoff Action="/login2fa" Handle="@_handle" />

@code {
    private InputModel Input { get; set; } = new();
    private bool _isProcessing;
    private string? _handle;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private bool RememberMe { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        if (Error == "invalid")
        {
            NotificationService.Notify(NotificationSeverity.Error, T("LoginWith2fa.ErrorTitle"), T("LoginWith2fa.InvalidCode"));
        }
    }

    private async Task OnSubmitAsync(InputModel model)
    {
        _isProcessing = true;

        _handle = LoginTokens.Protect(
            new TwoFactorLoginInfo(
                Code: model.TwoFactorCode!,
                RememberMe: RememberMe,
                RememberMachine: model.RememberMachine,
                ReturnUrl: ReturnUrl
            )
        );
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(7, MinimumLength = 6)]
        public string? TwoFactorCode { get; set; }

        public bool RememberMachine { get; set; }
    }

}
