@page "/Account/ConfirmEmailChange"
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.WebUtilities

@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject NavigationManager NavigationManager
@inject IServiceProvider Services

<AppPageTitle Title="@T("ConfirmEmailChange.PageTitle")" />

<div class="rz-p-4 rz-p-md-8">
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Center">

            <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">@T("ConfirmEmailChange.Heading")</RadzenText>

            @if (_succeeded)
            {
                <RadzenAlert AlertStyle="AlertStyle.Success" Shade="Shade.Lighter" Variant="Variant.Flat" AllowClose="false">
                    @T("ConfirmEmailChange.Success")
                </RadzenAlert>
                <RadzenButton Text="@T("ConfirmEmailChange.GoToProfile")"
                              ButtonStyle="ButtonStyle.Primary"
                              Click=@(() => NavigationManager.NavigateTo("/Account/Manage/Profile")) />
            }
            else
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" Variant="Variant.Flat" AllowClose="false">
                    @_error
                </RadzenAlert>
                <RadzenButton Text="@T("ConfirmEmailChange.GoHome")"
                              ButtonStyle="ButtonStyle.Primary"
                              Click=@(() => NavigationManager.NavigateTo("/")) />
            }

        </RadzenStack>
    </RadzenCard>
</div>

@code {
    private bool _succeeded;
    private string? _error;

    [SupplyParameterFromQuery]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _error = T("ConfirmEmailChange.GenericError");

        if (UserId is null || Email is null || Code is null)
        {
            _error = T("ConfirmEmailChange.InvalidLink");
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            // Do not reflect the supplied UserId back to the client (#13, CWE-204).
            _error = T("ConfirmEmailChange.InvalidLink");
            return;
        }

        var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ChangeEmailAsync(user, Email, code);
        if (!result.Succeeded)
        {
            _error = T("ConfirmEmailChange.ChangeFailedError");
            return;
        }

        // In our UI email and user name are one and the same
        var setUserNameResult = await UserManager.SetUserNameAsync(user, Email);
        if (!setUserNameResult.Succeeded)
        {
            _error = T("ConfirmEmailChange.UsernameUpdateError");
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        _succeeded = true;
    }

    // Resolved through IServiceProvider rather than an injected IStringLocalizer so the page
    // still renders on a host (or bUnit test) without localization registered.
    private string T(string key) => Services.IdentityText(key);
}
