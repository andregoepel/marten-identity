@page "/Account/ResetPassword"
@attribute [AllowAnonymous]
@layout LoginLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.WebUtilities

@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject IOptions<IdentityOptions> IdentityOptions
@inject IServiceProvider Services

<AppPageTitle Title="@T("ResetPassword.PageTitle")" />

<div class="ag-login-head">
    <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4" Text="@T("ResetPassword.Heading")" />
    <RadzenText TextStyle="TextStyle.Body2" class="ag-login-sub" Text="@T("ResetPassword.Subheading")" />
</div>

@if (_invalidLink)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" Variant="Variant.Flat" AllowClose="false">
        @T("ResetPassword.InvalidLink")
    </RadzenAlert>
    <div class="ag-login-actions">
        <RadzenButton Text="@T("ResetPassword.RequestNewLink")"
                      ButtonStyle="ButtonStyle.Primary"
                      Click=@(() => NavigationManager.NavigateTo("/Account/ForgotPassword")) />
    </div>
}
else
{
    <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnValidSubmitAsync>
        <RadzenStack Gap="1.25rem">

            <FormField Label="@T("ResetPassword.Email")" For="Email">
                <RadzenTextBox @bind-Value=@Input.Email
                               Name="Email"
                               Placeholder="name@example.com"
                               AutoCompleteType="AutoCompleteType.Email"
                               Style="width:100%" />
                <RadzenRequiredValidator Component="Email" Text="@T("ResetPassword.EmailRequired")" />
                <RadzenEmailValidator Component="Email" Text="@T("ResetPassword.EmailInvalid")" />
            </FormField>

            <FormField Label="@T("ResetPassword.NewPassword")" For="Password">
                <RadzenPassword @bind-Value=@Input.Password
                                Name="Password"
                                Style="width:100%" />
                <RadzenRequiredValidator Component="Password" Text="@T("ResetPassword.PasswordRequired")" />
                <RadzenLengthValidator Component="Password" Min="@MinPasswordLength" Max="100"
                                       Text="@T("ResetPassword.PasswordLength", MinPasswordLength)" />
            </FormField>

            <FormField Label="@T("ResetPassword.ConfirmPassword")" For="ConfirmPassword">
                <RadzenPassword @bind-Value=@Input.ConfirmPassword
                                Name="ConfirmPassword"
                                Style="width:100%" />
                <RadzenRequiredValidator Component="ConfirmPassword" Text="@T("ResetPassword.ConfirmPasswordRequired")" />
                <RadzenCompareValidator Component="ConfirmPassword"
                                        Value=@Input.Password
                                        Text="@T("ResetPassword.PasswordMismatch")"
                                        Operator="CompareOperator.Equal" />
            </FormField>

            <div class="ag-login-actions">
                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="@T("ResetPassword.Submit")"
                              ButtonStyle="ButtonStyle.Primary"
                              IsBusy=@_isProcessing
                              BusyText="@T("ResetPassword.Resetting")" />
            </div>

        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    private InputModel Input { get; set; } = new();
    private bool _isProcessing;
    private bool _invalidLink;

    private int MinPasswordLength => IdentityOptions.Value.Password.RequiredLength;

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override void OnInitialized()
    {
        if (Code is null)
        {
            _invalidLink = true;
            return;
        }

        Input.Code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
    }

    private async Task OnValidSubmitAsync(InputModel model)
    {
        _isProcessing = true;

        try
        {
            var user = await UserManager.FindByEmailAsync(model.Email);
            if (user is null)
            {
                // Don't reveal that the user does not exist
                NavigationManager.NavigateTo("/Account/ResetPasswordConfirmation");
                return;
            }

            var result = await UserManager.ResetPasswordAsync(user, model.Code, model.Password);
            if (result.Succeeded)
            {
                NavigationManager.NavigateTo("/Account/ResetPasswordConfirmation");
                return;
            }

            NotificationService.Notify(NotificationSeverity.Error, T("ResetPassword.ResetFailedTitle"), string.Join(", ", result.Errors.Select(e => e.Description)));
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [StringLength(100, MinimumLength = 12)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare(nameof(Password))]
        public string ConfirmPassword { get; set; } = "";

        [Required]
        public string Code { get; set; } = "";
    }

    // Resolved through IServiceProvider rather than an injected IStringLocalizer so the page
    // still renders on a host (or bUnit test) without localization registered.
    private string T(string key) => Services.IdentityText(key);

    private string T(string key, params object[] arguments) =>
        Services.IdentityText(key, arguments);
}
