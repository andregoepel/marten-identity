@page "/Account/ConfirmEmail"
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.WebUtilities

@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject IServiceProvider Services

<AppPageTitle Title="@T("ConfirmEmail.PageTitle")" />

<div class="rz-p-4 rz-p-md-8">
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Center">

            <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">@T("ConfirmEmail.Heading")</RadzenText>

            @if (_succeeded)
            {
                <RadzenAlert AlertStyle="AlertStyle.Success" Shade="Shade.Lighter" Variant="Variant.Flat" AllowClose="false">
                    @T("ConfirmEmail.Success")
                </RadzenAlert>
                <RadzenButton Text="@T("ConfirmEmail.LogIn")"
                              ButtonStyle="ButtonStyle.Primary"
                              Click=@(() => NavigationManager.NavigateTo("/Account/Login")) />
            }
            else
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" Variant="Variant.Flat" AllowClose="false">
                    @_error
                </RadzenAlert>
                <RadzenButton Text="@T("ConfirmEmail.GoHome")"
                              ButtonStyle="ButtonStyle.Primary"
                              Click=@(() => NavigationManager.NavigateTo("/")) />
            }

        </RadzenStack>
    </RadzenCard>
</div>

@code {
    private bool _succeeded;
    private string? _error;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _error = T("ConfirmEmail.GenericError");

        if (UserId is null || Code is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            // Do not reflect the supplied UserId back to the client (#13, CWE-204).
            _error = T("ConfirmEmail.UserNotFoundError");
            return;
        }

        var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ConfirmEmailAsync(user, code);
        _succeeded = result.Succeeded;
        if (!result.Succeeded)
            _error = T("ConfirmEmail.ConfirmFailedError");
    }

    // Resolved through IServiceProvider rather than an injected IStringLocalizer so the page
    // still renders on a host (or bUnit test) without localization registered.
    private string T(string key) => Services.IdentityText(key);
}
