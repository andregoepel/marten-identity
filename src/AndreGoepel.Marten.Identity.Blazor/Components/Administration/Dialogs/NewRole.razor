@inherits IdentityLocalizedComponentBase
@inject DialogService DialogService
@inject RoleManager<Role> RoleManager

<RadzenStack Gap="1rem" Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween">
    <RadzenStack>
        <RadzenLabel Text="@T("NewRole.RolenameLabel")" Component="Rolename" />
        <RadzenTextBox Name="Rolename" Style="width: 100%" @bind-Value="@Rolename" />
    </RadzenStack>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Click="@(() => SaveRole())" ButtonStyle="ButtonStyle.Primary" Text="@T("NewRole.SaveButton")" Style="width: 120px" />
        <RadzenButton Click="@(() => DialogService.Close(false))" ButtonStyle="ButtonStyle.Light" Text="@T("NewRole.CloseButton")" Style="width: 120px" />
    </RadzenStack>
</RadzenStack>

@code {
    private string Rolename { get; set; } = "";

    private async Task SaveRole()
    {
        var newRole = new Role { Name = Rolename };

        var result = await RoleManager.CreateAsync(newRole);

        if (!result.Succeeded)
        {
            var reasons = string.Join("\r\n", result.Errors.Select(error => error.Description));
            await DialogService.Alert(T("NewRole.CreateFailedDetail", reasons), T("NewRole.CreateFailedTitle"));
        }
        else
        {
            DialogService.Close(true);
        }
    }
}
