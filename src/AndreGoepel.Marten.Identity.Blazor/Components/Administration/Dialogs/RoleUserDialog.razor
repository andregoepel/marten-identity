@inherits IdentityLocalizedComponentBase
@inject DialogService DialogService
@inject ConfirmService Confirm
@inject UserManager<User> UserManager
@inject RoleManager<Role> RoleManager

<RadzenStack Gap="1rem" Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween">
    <RadzenCard Style="padding: 0; overflow: hidden;">
        <RadzenDataGrid Data="@_users"
                        AllowFiltering="false"
                        AllowColumnResize="false"
                        AllowAlternatingRows="false"
                        AllowSorting="true"
                        PageSize="5"
                        AllowPaging="true"
                        PagerHorizontalAlign="HorizontalAlign.Left"
                        ShowPagingSummary="true"
                        Density="Density.Compact"
                        Style="width: 100%;">
            <Columns>
                <RadzenDataGridColumn Property="@nameof(User.UserName)" Title="@T("RoleUserDialog.NameColumn")" />
                <RadzenDataGridColumn Title="@T("RoleUserDialog.ActionsColumn")" Sortable="false" Filterable="false" Width="120px" TextAlign="TextAlign.Right">
                    <Template Context="data">
                        <div class="ag-row-actions">
                            <RadzenButton Text="@T("RoleUserDialog.RemoveButton")"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Size="ButtonSize.Small"
                                          Click="@(() => RemoveUser(data))" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Click="@(() => DialogService.Close(true))" ButtonStyle="ButtonStyle.Light" Text="@T("RoleUserDialog.CloseButton")" Style="width: 120px" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public required string RoleId { get; set; }

    private List<User> _users = [];
    private Role _role = default!;

    private async Task RemoveUser(User user)
    {
        if(string.IsNullOrEmpty(_role.Name))
            return;

        if (await Confirm.ConfirmAsync(T("RoleUserDialog.RemoveConfirmMessage"), T("RoleUserDialog.RemoveConfirmTitle")))
        {
            if (user.RootUser && _role.Name == Roles.Administrator)
            {
                await DialogService.Alert(T("RoleUserDialog.RootUserCannotBeRemoved", user.UserName ?? "", _role.Name, Roles.Administrator), T("RoleUserDialog.ErrorTitle"));
                return;
            }

            var deleteResult = await UserManager.RemoveFromRoleAsync(user, _role.Name);
            if (deleteResult.Succeeded)
            {
                _users = _users.Where(u => u.Id != user.Id).ToList();
                await InvokeAsync(StateHasChanged);
            }
            else
                await DialogService.Alert(T("RoleUserDialog.UserCouldNotBeDeleted"), T("RoleUserDialog.ErrorTitle"));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await RoleManager.FindByIdAsync(RoleId) ?? throw new InvalidOperationException("Role not found");

        if(!string.IsNullOrEmpty(_role.Name))
            _users = [.. await UserManager.GetUsersInRoleAsync(_role.Name)];

        await base.OnInitializedAsync();
    }
}
