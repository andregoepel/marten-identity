@inherits IdentityLocalizedComponentBase
@inject DialogService DialogService
@inject UserManager<User> UserManager
@inject RoleManager<Role> RoleManager

<RadzenStack Gap="1rem" Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween">
    <RadzenStack>
    <RadzenListBox
        @bind-Value="@_values"
        Data="@_roles"
        TextProperty="@nameof(Role.Name)"
        ValueProperty="@nameof(Role.RoleId)"
        Multiple="true"
        AllowClear="true"
        Placeholder="@T("UserRoleDialog.RolesPlaceholder")"
        Change="@(() => OnChange())"
        />
    </RadzenStack>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Click="@(() => SaveRoles())" ButtonStyle="ButtonStyle.Primary" Text="@T("UserRoleDialog.SaveButton")" Style="width: 120px" />
        <RadzenButton Click="@(() => DialogService.Close(false))" ButtonStyle="ButtonStyle.Light" Text="@T("UserRoleDialog.CloseButton")" Style="width: 120px" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public required string UserId { get; set; }

    private IReadOnlyList<Role> _roles = default!;
    private User _user = default!;
    private List<RoleId> _values = [];

    private RoleId AdminRole => _roles.First(role => role.Name == Roles.Administrator).RoleId;

    private async Task OnChange()
    {
        if (_user.RootUser && !_values.Contains(AdminRole))
        {
            await DialogService.Alert(T("UserRoleDialog.RootUserMustHaveAdminRole", Roles.Administrator), T("UserRoleDialog.WarningTitle"));
            _values.Add(AdminRole);
        }
    }

    private async Task SaveRoles()
    {
        var newRoles =
            from value in _values.Except(_user.Roles)
            join role in _roles on value equals role.RoleId
            select role.Name;

        await UserManager.AddToRolesAsync(_user, newRoles);

        var removedRoles =
            from value in _user.Roles.Except(_values)
            join role in _roles on value equals role.RoleId
            select role.Name;

        await UserManager.RemoveFromRolesAsync(_user, removedRoles);

        DialogService.Close(true);
    }

}
