@page "/Administration/Roles"
@rendermode InteractiveServer
@using AndreGoepel.Marten.Identity.Blazor.Components.Administration.Dialogs

@inject RoleManager<Role> RoleManager
@inject RoleStore<Role> RoleStore
@inject DialogService DialogService
@inject ContextMenuService ContextMenuService

@attribute [Authorize(Roles = "Administrator")]

<IdentityPageTitle Title="Roles" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <RadzenRow AlignItems="AlignItems.Center">
            <RadzenColumn>
                <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Roles</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Manage user roles and permissions</RadzenText>
            </RadzenColumn>
            <RadzenColumn class="rz-text-align-right">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" JustifyContent="JustifyContent.End">
                    <RadzenCheckBox Name="ShowDeleted"
                                    @bind-Value="@ShowDeleted"
                                    Change="@((bool value) => ShowDeletedChangedAsync(value))" />
                    <RadzenLabel Text="Show deleted" Component="ShowDeleted" />
                    <RadzenButton Text="New role"
                                  Icon="add"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small"
                                  Click="@NewRoleAsync" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        <RadzenCard Style="padding: 0; overflow: hidden;">
            <RadzenDataGrid @ref="_rolesGrid"
                            Data="@_roles"
                            AllowFiltering="false"
                            AllowColumnResize="false"
                            AllowAlternatingRows="false"
                            AllowSorting="true"
                            PageSize="10"
                            AllowPaging="true"
                            PagerHorizontalAlign="HorizontalAlign.Left"
                            ShowPagingSummary="true"
                            Density="Density.Compact"
                            Style="width: 100%;">
                <Columns>
                    <RadzenDataGridColumn Property="@nameof(Role.Name)" Title="Role name" Width="260px">
                        <Template Context="role">
                            <div style="display:flex; flex-direction:column; gap:2px;">
                                <span class="af-cell-name">@role.Name</span>
                                <span class="af-cell-id">@role.Id</span>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(Role.CreatedAt)" FormatString="{0:d} {0:t}" Title="Created" Width="160px" />
                    <RadzenDataGridColumn Property="@nameof(Role.ChangedAt)" FormatString="{0:d} {0:t}" Title="Changed" Width="160px" />
                    <RadzenDataGridColumn Property="@nameof(Role.Deleted)" Title="Status" Width="110px">
                        <Template Context="role">
                            @if (role.Deleted)
                            {
                                <span class="af-badge af-badge-danger">Deleted</span>
                            }
                            else
                            {
                                <span class="af-badge af-badge-success">Active</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Actions" Sortable="false" Filterable="false" Width="150px" TextAlign="TextAlign.Right">
                        <Template Context="data">
                            <div class="af-row-actions">
                                <RadzenButton Text="Users"
                                              ButtonStyle="ButtonStyle.Light"
                                              Size="ButtonSize.Small"
                                              Disabled="@data.Deleted"
                                              Click="@(() => ShowUsersAsync(data))" />
                                @if (RowHasMenu(data))
                                {
                                    <RadzenButton Icon="more_horiz"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  Size="ButtonSize.Small"
                                                  class="af-icon-btn"
                                                  Click="@(args => OpenRowMenu(args, data))" />
                                }
                            </div>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private IReadOnlyList<Role>? _roles;
    private RadzenDataGrid<Role>? _rolesGrid;

    private bool ShowDeleted { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadRolesAsync();
    }

    private async Task NewRoleAsync()
    {
        var result = await DialogService.OpenAsync<NewRole>("Create New Role");
        if (result is true)
        {
            await LoadRolesAsync();
        }
    }

    private async Task ShowUsersAsync(Role role)
    {
        if (string.IsNullOrWhiteSpace(role?.Name)) return;

        await DialogService.OpenAsync<RoleUserDialog>(
            $"Users in role: {role.Name}",
            new Dictionary<string, object?> { { "RoleId", role.Id } },
            new DialogOptions { Width = "700px", Height = "500px" }
        );
    }

    private async Task DeleteRoleAsync(Role role)
    {
        if (await DialogService.Confirm(
            $"Are you sure you want to delete the role **{role.Name}**?",
            "Delete Role") != true)
        {
            return;
        }

        var result = await RoleManager.DeleteAsync(role);

        if (result.Succeeded)
        {
            await LoadRolesAsync();
        }
        else
        {
            await DialogService.Alert(
                string.Join("\n", result.Errors.Select(e => e.Description)),
                "Deletion failed");
        }
    }

    private async Task RestoreRoleAsync(Role role)
    {
        if (await DialogService.Confirm(
            $"Are you sure you want to restore the role **{role.Name}**?",
            "Restore Role") != true)
        {
            return;
        }

        var result = await RoleStore.RestoreAsync(role);

        if (result.Succeeded)
        {
            await LoadRolesAsync();
        }
        else
        {
            await DialogService.Alert(
                string.Join("\n", result.Errors.Select(e => e.Description)),
                "Restore failed");
        }
    }

    private async Task ShowDeletedChangedAsync(bool value)
    {
        ShowDeleted = value;
        await LoadRolesAsync();
    }

    private static bool RowHasMenu(Role role) => role.Deleted || role.Deletable;

    private void OpenRowMenu(MouseEventArgs args, Role role)
    {
        var items = new List<ContextMenuItem>();
        if (role.Deleted)
        {
            items.Add(new ContextMenuItem { Text = "Restore", Value = "restore" });
        }
        else if (role.Deletable)
        {
            items.Add(new ContextMenuItem { Text = "Delete", Value = "delete" });
        }

        ContextMenuService.Open(args, items, async e =>
        {
            ContextMenuService.Close();
            switch (e.Value as string)
            {
                case "restore":
                    await RestoreRoleAsync(role);
                    break;
                case "delete":
                    await DeleteRoleAsync(role);
                    break;
            }
        });
    }
}
