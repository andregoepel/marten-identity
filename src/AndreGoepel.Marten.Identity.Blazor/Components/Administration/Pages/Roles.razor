@page "/Administration/Roles"
@rendermode InteractiveServer
@inherits IdentityLocalizedComponentBase
@using AndreGoepel.Marten.Identity.Blazor.Components.Administration.Dialogs

@inject RoleManager<Role> RoleManager
@inject RoleStore<Role> RoleStore
@inject DialogService DialogService
@inject ConfirmService Confirm
@inject ContextMenuService ContextMenuService

@attribute [Authorize(Roles = "Administrator")]

<AppPageTitle Title="@T("Roles.PageTitle")" Breadcrumb="@T("Roles.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("Roles.PageTitle")" Subtitle="@T("Roles.Subtitle")">
            <Actions>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                    <RadzenCheckBox Name="ShowDeleted"
                                    @bind-Value="@ShowDeleted"
                                    Change="@((bool value) => ShowDeletedChangedAsync(value))" />
                    <RadzenLabel Text="@T("Roles.ShowDeleted")" Component="ShowDeleted" />
                    <RadzenButton Text="@T("Roles.NewRoleButton")"
                                  Icon="add"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small"
                                  Click="@NewRoleAsync" />
                </RadzenStack>
            </Actions>
        </PageHeader>

        <DataCard>
            <GridToolbar Search="_filter" SearchChanged="OnFilterChangedAsync" SearchPlaceholder="@T("Roles.SearchPlaceholder")"
                         Count="@T("Roles.Count", FilteredRoles.Count, _roles?.Count ?? 0)" />
            <RadzenDataGrid @ref="_rolesGrid"
                            Data="@FilteredRoles"
                            AllowFiltering="false"
                            AllowColumnResize="false"
                            AllowAlternatingRows="false"
                            AllowSorting="true"
                            PageSize="10"
                            AllowPaging="true"
                            PagerHorizontalAlign="HorizontalAlign.Left"
                            ShowPagingSummary="true"
                            Density="Density.Compact"
                            Style="width: 100%;">
                <Columns>
                    <RadzenDataGridColumn Property="@nameof(Role.Name)" Title="@T("Roles.RoleNameColumn")" Width="260px">
                        <Template Context="role">
                            <div style="display:flex; flex-direction:column; gap:2px;">
                                <span class="ag-cell-name">@role.Name</span>
                                <span class="ag-cell-id">@role.Id</span>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(Role.CreatedAt)" FormatString="{0:d} {0:t}" Title="@T("Roles.CreatedColumn")" Width="160px" />
                    <RadzenDataGridColumn Property="@nameof(Role.ChangedAt)" FormatString="{0:d} {0:t}" Title="@T("Roles.ChangedColumn")" Width="160px" />
                    <RadzenDataGridColumn Property="@nameof(Role.Deleted)" Title="@T("Roles.StatusColumn")" Width="110px">
                        <Template Context="role">
                            @if (role.Deleted)
                            {
                                <StatusBadge Text="@T("Roles.Deleted")" Variant="BadgeVariant.Danger" />
                            }
                            else
                            {
                                <StatusBadge Text="@T("Roles.Active")" Variant="BadgeVariant.Success" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="@T("Roles.ActionsColumn")" Sortable="false" Filterable="false" Width="150px" TextAlign="TextAlign.Right">
                        <Template Context="data">
                            <RowActions>
                                <RadzenButton Text="@T("Roles.UsersButton")"
                                              ButtonStyle="ButtonStyle.Light"
                                              Size="ButtonSize.Small"
                                              Disabled="@data.Deleted"
                                              Click="@(() => ShowUsersAsync(data))" />
                                @if (RowHasMenu(data))
                                {
                                    <IconButton Icon="more_horiz" Title="@T("Roles.MoreActions")" Click="@(args => OpenRowMenu(args, data))" />
                                }
                            </RowActions>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </DataCard>

    </RadzenStack>
</div>

@code {
    private IReadOnlyList<Role>? _roles;
    private RadzenDataGrid<Role>? _rolesGrid;
    private string _filter = "";

    private bool ShowDeleted { get; set; }

    private IReadOnlyList<Role> FilteredRoles =>
        (_roles ?? Array.Empty<Role>())
            .Where(r => string.IsNullOrWhiteSpace(_filter)
                        || (r.Name?.Contains(_filter, StringComparison.OrdinalIgnoreCase) ?? false)
                        || r.Id.ToString().Contains(_filter, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private async Task OnFilterChangedAsync(string value)
    {
        _filter = value;
        if (_rolesGrid is not null)
        {
            await _rolesGrid.Reload();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRolesAsync();
    }

    private async Task NewRoleAsync()
    {
        var result = await DialogService.OpenAsync<NewRole>(T("Roles.NewRoleDialogTitle"));
        if (result is true)
        {
            await LoadRolesAsync();
        }
    }

    private async Task ShowUsersAsync(Role role)
    {
        if (string.IsNullOrWhiteSpace(role?.Name)) return;

        await DialogService.OpenAsync<RoleUserDialog>(
            T("Roles.UsersInRoleDialogTitle", role.Name),
            new Dictionary<string, object?> { { "RoleId", role.Id } },
            new DialogOptions { Width = "700px", Height = "500px" }
        );
    }

    private async Task DeleteRoleAsync(Role role)
    {
        if (!await Confirm.ConfirmDeleteAsync(role.Name ?? T("Roles.ThisRole"), title: T("Roles.DeleteRoleConfirmTitle")))
        {
            return;
        }

        var result = await RoleManager.DeleteAsync(role);

        if (result.Succeeded)
        {
            await LoadRolesAsync();
        }
        else
        {
            await DialogService.Alert(
                string.Join("\n", result.Errors.Select(e => e.Description)),
                T("Roles.DeletionFailedTitle"));
        }
    }

    private async Task RestoreRoleAsync(Role role)
    {
        if (!await Confirm.ConfirmAsync(T("Roles.RestorePrompt", role.Name ?? ""), T("Roles.RestoreRoleConfirmTitle"), okText: T("Roles.Restore")))
        {
            return;
        }

        var result = await RoleStore.RestoreAsync(role);

        if (result.Succeeded)
        {
            await LoadRolesAsync();
        }
        else
        {
            await DialogService.Alert(
                string.Join("\n", result.Errors.Select(e => e.Description)),
                T("Roles.RestoreFailedTitle"));
        }
    }

    private async Task ShowDeletedChangedAsync(bool value)
    {
        ShowDeleted = value;
        await LoadRolesAsync();
    }

    private static bool RowHasMenu(Role role) => role.Deleted || role.Deletable;

    private void OpenRowMenu(MouseEventArgs args, Role role)
    {
        var items = new List<ContextMenuItem>();
        if (role.Deleted)
        {
            items.Add(new ContextMenuItem { Text = T("Roles.Restore"), Value = "restore", Icon = "restore" });
        }
        else if (role.Deletable)
        {
            items.Add(new ContextMenuItem { Text = T("Roles.DeleteMenuItem"), Value = "delete", Icon = "delete", IconColor = "var(--ag-danger)" });
        }

        ContextMenuService.Open(args, items, async e =>
        {
            ContextMenuService.Close();
            switch (e.Value as string)
            {
                case "restore":
                    await RestoreRoleAsync(role);
                    break;
                case "delete":
                    await DeleteRoleAsync(role);
                    break;
            }
        });
    }
}
