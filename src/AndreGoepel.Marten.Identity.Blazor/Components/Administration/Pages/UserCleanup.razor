@page "/Administration/UserCleanup"
@rendermode InteractiveServer

@inject CleanupSettingsService CleanupSettingsService
@inject NotificationService NotificationService

@attribute [Authorize(Roles = "Administrator")]

<IdentityPageTitle Title="User Cleanup" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">User Cleanup</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                Configure automatic permanent deletion of soft-deleted users.
            </RadzenText>
        </div>

        <RadzenCard>
            <RadzenStack Gap="1.25rem">

                <RadzenStack Gap="0.4rem">
                    <RadzenLabel Text="Retention period (days)" Component="RetentionDays" />
                    <RadzenNumeric @bind-Value="@_input.RetentionDays" Name="RetentionDays" Min="1" Max="3650" Style="width: 140px;" />
                </RadzenStack>

                <RadzenStack Gap="0.4rem">
                    <RadzenLabel Text="Cron schedule" Component="CronSchedule" />
                    <RadzenTextBox @bind-Value="@_input.CronSchedule" Name="CronSchedule"
                                   Style="width: 240px; max-width: 100%; font-family: 'JetBrains Mono', ui-monospace, monospace;" />
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); line-height: 1.55;">
                        Quartz cron format: seconds minutes hours day-of-month month day-of-week.
                        Example: <code>0 0 3 * * ?</code> runs daily at 03:00 UTC.
                        Changes take effect immediately.
                    </RadzenText>
                </RadzenStack>

                @if (_nextFireTime.HasValue)
                {
                    <div class="af-info-box">
                        <span class="af-info-box-label">Next scheduled run</span>
                        <span class="af-info-box-value">@_nextFireTime.Value.ToString("f") UTC</span>
                    </div>
                }

                <div class="af-card-actions">
                    <RadzenButton Text="Save changes"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="@SaveAsync"
                                  IsBusy="@_saving" />
                </div>

            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private InputModel _input = new();
    private DateTimeOffset? _nextFireTime;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        var settings = await CleanupSettingsService.GetAsync();
        _input.RetentionDays = settings.RetentionDays;
        _input.CronSchedule = settings.CronSchedule;
        _nextFireTime = await CleanupSettingsService.GetNextFireTimeAsync();
    }

    private async Task SaveAsync()
    {
        _saving = true;

        try
        {
            var settings = new CleanupSettings
            {
                RetentionDays = _input.RetentionDays,
                CronSchedule = _input.CronSchedule,
            };

            await CleanupSettingsService.SaveAsync(settings);
            _nextFireTime = await CleanupSettingsService.GetNextFireTimeAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Saved", "Settings saved.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class InputModel
    {
        public int RetentionDays { get; set; } = 30;
        public string CronSchedule { get; set; } = "0 0 0 * * ?";
    }
}
