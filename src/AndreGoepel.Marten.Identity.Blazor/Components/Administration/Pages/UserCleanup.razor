@page "/Administration/UserCleanup"
@rendermode InteractiveServer
@inherits IdentityLocalizedComponentBase

@inject CleanupSettingsService CleanupSettingsService
@inject NotificationService NotificationService

@attribute [Authorize(Roles = "Administrator")]

<AppPageTitle Title="@T("UserCleanup.PageTitle")" Breadcrumb="@T("UserCleanup.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("UserCleanup.PageTitle")" Subtitle="@T("UserCleanup.Subtitle")" />

        <CardForm TItem="InputModel" Data="_input" Submit="SaveAsync" IsBusy="_saving">
            <FormField Label="@T("UserCleanup.RetentionDaysLabel")" For="RetentionDays">
                <RadzenNumeric @bind-Value="@_input.RetentionDays" Name="RetentionDays" Min="1" Max="3650" Style="width: 140px;" />
            </FormField>

            <FormField Label="@T("UserCleanup.CronScheduleLabel")" For="CronSchedule"
                       Hint="@T("UserCleanup.CronScheduleHint")">
                <RadzenTextBox @bind-Value="@_input.CronSchedule" Name="CronSchedule"
                               Style="width: 240px; max-width: 100%; font-family: 'JetBrains Mono', ui-monospace, monospace;" />
            </FormField>

            @if (_nextFireTime.HasValue)
            {
                <InfoBox Label="@T("UserCleanup.NextRunLabel")" Value="@($"{_nextFireTime.Value:f} UTC")" />
            }
        </CardForm>

    </RadzenStack>
</div>

@code {
    private InputModel _input = new();
    private DateTimeOffset? _nextFireTime;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        var settings = await CleanupSettingsService.GetAsync();
        _input.RetentionDays = settings.RetentionDays;
        _input.CronSchedule = settings.CronSchedule;
        _nextFireTime = await CleanupSettingsService.GetNextFireTimeAsync();
    }

    private async Task SaveAsync()
    {
        _saving = true;

        try
        {
            var settings = new CleanupSettings
            {
                RetentionDays = _input.RetentionDays,
                CronSchedule = _input.CronSchedule,
            };

            await CleanupSettingsService.SaveAsync(settings);
            _nextFireTime = await CleanupSettingsService.GetNextFireTimeAsync();
            NotificationService.Notify(NotificationSeverity.Success, T("UserCleanup.SavedTitle"), T("UserCleanup.SavedMessage"));
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("UserCleanup.ErrorTitle"), ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class InputModel
    {
        public int RetentionDays { get; set; } = 30;
        public string CronSchedule { get; set; } = "0 0 0 * * ?";
    }
}
