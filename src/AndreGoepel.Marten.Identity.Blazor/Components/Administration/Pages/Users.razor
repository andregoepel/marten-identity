@page "/Administration/Users"
@rendermode InteractiveServer
@using AndreGoepel.Marten.Identity.Blazor.Components.Administration.Dialogs

@inject UserManager<User> UserManager
@inject UserStore<User> UserStore
@inject DialogService DialogService

@attribute [Authorize(Roles = "Administrator")]

<IdentityPageTitle Title="Users" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <RadzenRow AlignItems="AlignItems.Center">
            <RadzenColumn>
                <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Users</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">Manage user accounts</RadzenText>
            </RadzenColumn>
            <RadzenColumn class="rz-text-align-right">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" JustifyContent="JustifyContent.End">
                    <RadzenCheckBox Name="ShowDeleted" @bind-Value="@ShowDeleted" Change="@((bool value) => ShowDeletedChangedAsync(value))" />
                    <RadzenLabel Text="Show deleted" Component="ShowDeleted" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        <RadzenCard Style="padding: 0; overflow: hidden;">
            <RadzenDataGrid Data="@_users"
                            AllowFiltering="false"
                            AllowColumnResize="false"
                            AllowAlternatingRows="false"
                            AllowSorting="true"
                            PageSize="10"
                            AllowPaging="true"
                            PagerHorizontalAlign="HorizontalAlign.Left"
                            ShowPagingSummary="true"
                            LogicalFilterOperator="LogicalFilterOperator.Or"
                            SelectionMode="DataGridSelectionMode.Single"
                            @bind-Value="@_selectedUsers"
                            Density="Density.Compact"
                            Style="width: 100%;">
                <Columns>
                    <RadzenDataGridColumn Property="@nameof(User.Email)" Title="Email" Width="240px">
                        <Template Context="user">
                            <div style="display:flex; flex-direction:column; gap:2px;">
                                <span style="font-weight:700; color:var(--af-text);">@user.Email</span>
                                <span style="font:400 10.5px 'JetBrains Mono', monospace; color:var(--af-faint);">@user.Id</span>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(User.CreatedAt)" FormatString="{0:d} {0:t}" Title="Created" Width="150px" />
                    <RadzenDataGridColumn Property="@nameof(User.ChangedAt)" FormatString="{0:d} {0:t}" Title="Changed" Width="150px" />
                    <RadzenDataGridColumn Property="@nameof(User.EmailConfirmed)" Title="Confirmed" Width="110px">
                        <Template Context="user">
                            @if (user.EmailConfirmed)
                            {
                                <span class="af-badge af-badge-success">Confirmed</span>
                            }
                            else
                            {
                                <span class="af-badge af-badge-danger">Unconfirmed</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(User.Deleted)" Title="Status" Width="100px">
                        <Template Context="user">
                            @if (user.Deleted)
                            {
                                <span class="af-badge af-badge-danger">Deleted</span>
                            }
                            else
                            {
                                <span class="af-badge af-badge-success">Active</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(User.Deletable)" Title="Deletable" Width="100px">
                        <Template Context="user">@(user.Deletable ? "Yes" : "No")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Actions" Sortable="false" Filterable="false" Width="200px">
                        <Template Context="data">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                @if (!data.Deleted)
                                {
                                    <RadzenButton Text="Roles" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="@(() => SetRolesAsync(data))" />
                                }
                                @if (data.Deletable && !data.Deleted)
                                {
                                    <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => DeleteUserAsync(data))" />
                                }
                                @if (data.Deleted)
                                {
                                    <RadzenButton Text="Restore" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Click="@(() => RestoreUserAsync(data))" />
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private IReadOnlyList<User>? _users;
    private IList<User> _selectedUsers = new List<User>();
    private bool ShowDeleted { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task SetRolesAsync(User user)
    {
        var result = await DialogService.OpenAsync<UserRoleDialog>("Edit User Roles",
            new Dictionary<string, object?>() { { "UserId", user.Id } },
            new DialogOptions() { Width = "600px", Height = "400px" });

        if (result == true)
        {
            await LoadUsersAsync();
        }
    }

    private async Task DeleteUserAsync(User user)
    {
        if (await DialogService.Confirm("Are you sure you want to delete this user?", "Delete User") == true)
        {
            var deleteResult = await UserManager.DeleteAsync(user);
            if (deleteResult.Succeeded)
            {
                await LoadUsersAsync();
            }
            else
            {
                await DialogService.Alert("User could not be deleted", "Error");
            }
        }
    }

    private async Task RestoreUserAsync(User user)
    {
        if (await DialogService.Confirm("Are you sure you want to restore this user?", "Restore User") == true)
        {
            var result = await UserStore.RestoreAsync(user);
            if (result.Succeeded)
            {
                await LoadUsersAsync();
            }
            else
            {
                await DialogService.Alert("User could not be restored", "Error");
            }
        }
    }

    private async Task ShowDeletedChangedAsync(bool value)
    {
        ShowDeleted = value;
        await LoadUsersAsync();
    }
}
