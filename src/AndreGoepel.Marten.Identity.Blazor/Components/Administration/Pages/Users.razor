@page "/Administration/Users"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using AndreGoepel.Marten.Identity.Blazor.Components.Administration.Dialogs
@using AndreGoepel.Marten.Identity.Blazor.Email

@inject UserManager<User> UserManager
@inject UserStore<User> UserStore
@inject DialogService DialogService
@inject ConfirmService Confirm
@inject ContextMenuService ContextMenuService
@inject UserInvitationMailer InvitationMailer
@inject NotificationService NotificationService

@attribute [Authorize(Roles = "Administrator")]

<AppPageTitle Title="@T("Users.PageTitle")" Breadcrumb="@T("Users.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("Users.PageTitle")" Subtitle="@T("Users.Subtitle")">
            <Actions>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                    <RadzenCheckBox Name="ShowDeleted" @bind-Value="@ShowDeleted" Change="@((bool value) => ShowDeletedChangedAsync(value))" />
                    <RadzenLabel Text="@T("Users.ShowDeleted")" Component="ShowDeleted" />
                    <RadzenButton Text="@T("Users.InviteUserButton")"
                                  Icon="person_add"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small"
                                  Click="@InviteUserAsync" />
                </RadzenStack>
            </Actions>
        </PageHeader>

        <DataCard>
            <GridToolbar Search="_filter" SearchChanged="OnFilterChangedAsync" SearchPlaceholder="@T("Users.SearchPlaceholder")"
                         Count="@T("Users.Count", FilteredUsers.Count, _users?.Count ?? 0)" />
            <RadzenDataGrid @ref="_usersGrid"
                            Data="@FilteredUsers"
                            AllowFiltering="false"
                            AllowColumnResize="false"
                            AllowAlternatingRows="false"
                            AllowSorting="true"
                            PageSize="10"
                            AllowPaging="true"
                            PagerHorizontalAlign="HorizontalAlign.Left"
                            ShowPagingSummary="true"
                            Density="Density.Compact"
                            Style="width: 100%;">
                <Columns>
                    <RadzenDataGridColumn Property="@nameof(User.Email)" Title="@T("Users.EmailColumn")" Width="240px">
                        <Template Context="user">
                            <div style="display:flex; flex-direction:column; gap:2px;">
                                <span class="ag-cell-name">@user.Email</span>
                                <span class="ag-cell-id">@user.Id</span>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(User.CreatedAt)" FormatString="{0:d} {0:t}" Title="@T("Users.CreatedColumn")" Width="150px" />
                    <RadzenDataGridColumn Property="@nameof(User.ChangedAt)" FormatString="{0:d} {0:t}" Title="@T("Users.ChangedColumn")" Width="150px" />
                    <RadzenDataGridColumn Property="@nameof(User.EmailConfirmed)" Title="@T("Users.ConfirmedColumn")" Width="110px">
                        <Template Context="user">
                            @if (user.EmailConfirmed)
                            {
                                <StatusBadge Text="@T("Users.Confirmed")" Variant="BadgeVariant.Success" />
                            }
                            else if (UserInvitationService.IsPending(user))
                            {
                                <StatusBadge Text="@T("Users.Invited")" Variant="BadgeVariant.Warning" />
                            }
                            else
                            {
                                <StatusBadge Text="@T("Users.Unconfirmed")" Variant="BadgeVariant.Danger" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(User.Deleted)" Title="@T("Users.StatusColumn")" Width="100px">
                        <Template Context="user">
                            @if (user.Deleted)
                            {
                                <StatusBadge Text="@T("Users.Deleted")" Variant="BadgeVariant.Danger" />
                            }
                            else
                            {
                                <StatusBadge Text="@T("Users.Active")" Variant="BadgeVariant.Success" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(User.Deletable)" Title="@T("Users.DeletableColumn")" Width="100px">
                        <Template Context="user">@(user.Deletable ? T("Users.Yes") : T("Users.No"))</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="@T("Users.ActionsColumn")" Sortable="false" Filterable="false" Width="150px" TextAlign="TextAlign.Right">
                        <Template Context="data">
                            <RowActions>
                                <RadzenButton Text="@T("Users.RolesButton")"
                                              ButtonStyle="ButtonStyle.Light"
                                              Size="ButtonSize.Small"
                                              Disabled="@data.Deleted"
                                              Click="@(() => SetRolesAsync(data))" />
                                @if (RowHasMenu(data))
                                {
                                    <IconButton Icon="more_horiz" Title="@T("Users.MoreActions")" Click="@(args => OpenRowMenu(args, data))" />
                                }
                            </RowActions>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </DataCard>

    </RadzenStack>
</div>

@code {
    private IReadOnlyList<User>? _users;
    private RadzenDataGrid<User>? _usersGrid;
    private string _filter = "";
    private bool ShowDeleted { get; set; }

    private IReadOnlyList<User> FilteredUsers =>
        (_users ?? Array.Empty<User>())
            .Where(u => string.IsNullOrWhiteSpace(_filter)
                        || (u.Email?.Contains(_filter, StringComparison.OrdinalIgnoreCase) ?? false)
                        || u.Id.ToString().Contains(_filter, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private async Task OnFilterChangedAsync(string value)
    {
        _filter = value;
        if (_usersGrid is not null)
        {
            await _usersGrid.Reload();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task SetRolesAsync(User user)
    {
        var result = await DialogService.OpenAsync<UserRoleDialog>(T("Users.EditUserRolesDialogTitle"),
            new Dictionary<string, object?>() { { "UserId", user.Id } },
            new DialogOptions() { Width = "600px", Height = "400px" });

        if (result == true)
        {
            await LoadUsersAsync();
        }
    }

    private async Task InviteUserAsync()
    {
        var result = await DialogService.OpenAsync<InviteUser>(T("Users.InviteUserDialogTitle"),
            new Dictionary<string, object?>(),
            new DialogOptions() { Width = "480px" });

        if (result == true)
        {
            NotificationService.Notify(NotificationSeverity.Success, T("Users.InvitationSent"));
            await LoadUsersAsync();
        }
    }

    private async Task ResendInvitationAsync(User user)
    {
        var result = await InvitationMailer.ResendAsync(user);
        if (result.Succeeded)
        {
            NotificationService.Notify(NotificationSeverity.Success, T("Users.InvitationResent"));
        }
        else
        {
            await DialogService.Alert(
                string.Join(", ", result.Errors.Select(e => e.Description)),
                T("Users.ResendInvitationFailedTitle")
            );
        }
    }

    private async Task DeleteUserAsync(User user)
    {
        if (await Confirm.ConfirmDeleteAsync(user.Email ?? T("Users.ThisUser"), title: T("Users.DeleteUserConfirmTitle")))
        {
            var deleteResult = await UserManager.DeleteAsync(user);
            if (deleteResult.Succeeded)
            {
                await LoadUsersAsync();
            }
            else
            {
                await DialogService.Alert(T("Users.UserCouldNotBeDeleted"), T("Users.ErrorTitle"));
            }
        }
    }

    private async Task RestoreUserAsync(User user)
    {
        if (await Confirm.ConfirmAsync(T("Users.RestorePrompt", user.Email ?? ""), T("Users.RestoreUserConfirmTitle"), okText: T("Users.Restore")))
        {
            var result = await UserStore.RestoreAsync(user);
            if (result.Succeeded)
            {
                await LoadUsersAsync();
            }
            else
            {
                await DialogService.Alert(T("Users.UserCouldNotBeRestored"), T("Users.ErrorTitle"));
            }
        }
    }

    private async Task ShowDeletedChangedAsync(bool value)
    {
        ShowDeleted = value;
        await LoadUsersAsync();
    }

    private static bool RowHasMenu(User user) =>
        user.Deleted || user.Deletable || UserInvitationService.IsPending(user);

    private void OpenRowMenu(MouseEventArgs args, User user)
    {
        var items = new List<ContextMenuItem>();
        if (user.Deleted)
        {
            items.Add(new ContextMenuItem { Text = T("Users.Restore"), Value = "restore", Icon = "restore" });
        }
        else
        {
            if (UserInvitationService.IsPending(user))
            {
                items.Add(new ContextMenuItem { Text = T("Users.ResendInvitationMenuItem"), Value = "resend", Icon = "mail" });
            }

            if (user.Deletable)
            {
                items.Add(new ContextMenuItem { Text = T("Users.DeleteMenuItem"), Value = "delete", Icon = "delete", IconColor = "var(--ag-danger)" });
            }
        }

        ContextMenuService.Open(args, items, async e =>
        {
            ContextMenuService.Close();
            switch (e.Value as string)
            {
                case "restore":
                    await RestoreUserAsync(user);
                    break;
                case "resend":
                    await ResendInvitationAsync(user);
                    break;
                case "delete":
                    await DeleteUserAsync(user);
                    break;
            }
        });
    }
}
