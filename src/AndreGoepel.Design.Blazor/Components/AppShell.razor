@implements IDisposable

@* Reusable application shell: a fixed sidebar (brand + nav + optional footer) and
   a main column with a topbar (hamburger + breadcrumb + actions) and the page body.
   App-neutral — the host supplies branding and fills the Sidebar / TopbarActions /
   SidebarFooter slots.

   Owns a BreadcrumbState and cascades it, so pages can set the topbar crumb (e.g.
   via IdentityPageTitle's Breadcrumb parameter). The responsive off-canvas drawer
   is driven by design.css + nav.js — the host must load nav.js (see App.razor). *@

<CascadingValue Value="_breadcrumb" IsFixed="true">
    <div class="ag-shell" data-nav-open="false">
        <div class="ag-backdrop" onclick="agNav.close()"></div>
        <nav class="ag-sidebar">
            <div class="ag-brand">
                <div class="ag-brand-mark">@Initial</div>
                <span class="ag-brand-name">@BrandName</span>
            </div>

            @Sidebar

            @if (SidebarFooter is not null)
            {
                <div class="ag-sidebar-footer">@SidebarFooter</div>
            }
        </nav>

        <div class="ag-main">
            <div class="ag-topbar">
                <div class="ag-topbar-left">
                    <button class="ag-hamburger" type="button" onclick="agNav.toggle()" aria-label="Toggle navigation">☰</button>
                    <span class="ag-topbar-title">@_breadcrumb.Value</span>
                </div>
                <div class="ag-topbar-actions">
                    @TopbarActions
                </div>
            </div>

            <div class="ag-content">
                @ChildContent
            </div>
        </div>
    </div>
</CascadingValue>

@code {
    /// <summary>Brand name shown in the sidebar.</summary>
    [Parameter, EditorRequired]
    public string BrandName { get; set; } = "";

    /// <summary>Single-character brand mark. Defaults to the first letter of <see cref="BrandName"/>.</summary>
    [Parameter]
    public string? BrandInitial { get; set; }

    /// <summary>Sidebar navigation (nav links / sections, using the ag-nav-* classes).</summary>
    [Parameter]
    public RenderFragment? Sidebar { get; set; }

    /// <summary>Right-hand topbar content (theme toggle, user chip, sign-in/out, …).</summary>
    [Parameter]
    public RenderFragment? TopbarActions { get; set; }

    /// <summary>Optional content pinned to the bottom of the sidebar.</summary>
    [Parameter]
    public RenderFragment? SidebarFooter { get; set; }

    /// <summary>The routed page body.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    // Owned here and cascaded so pages can set the topbar breadcrumb; re-render on change.
    private readonly BreadcrumbState _breadcrumb = new();

    private string Initial =>
        !string.IsNullOrEmpty(BrandInitial) ? BrandInitial!
        : string.IsNullOrEmpty(BrandName) ? "?"
        : BrandName[..1].ToUpperInvariant();

    protected override void OnInitialized() => _breadcrumb.Changed += OnBreadcrumbChanged;

    private void OnBreadcrumbChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => _breadcrumb.Changed -= OnBreadcrumbChanged;
}
