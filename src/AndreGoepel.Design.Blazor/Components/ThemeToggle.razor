@* Light / auto / dark theme switch. Interactive so button clicks reach the
   browser-side agTheme helper that owns data-theme + localStorage. *@
@rendermode InteractiveServer
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="ag-theme-toggle" role="group" aria-label="Theme">
    @foreach (var mode in Modes)
    {
        <button type="button"
                class="ag-theme-btn @(mode.Key == _current ? "ag-active" : string.Empty)"
                title="@mode.Title"
                aria-label="@mode.Title"
                aria-pressed="@(mode.Key == _current)"
                @onclick="() => SetAsync(mode.Key)">
            <AppIcon Name="@mode.Icon" Size="14" />
        </button>
    }
</div>

@code {
    private string _current = "auto";

    private sealed record Mode(string Key, string Icon, string Title);

    private static readonly Mode[] Modes =
    [
        new("light", "sun", "Light"),
        new("auto", "monitor", "Match system"),
        new("dark", "moon", "Dark"),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _current = await JS.InvokeAsync<string>("agTheme.get");
            StateHasChanged();
        }
        catch (JSException)
        {
            // Script not ready yet (e.g. during prerender) — keep the default.
        }
    }

    private async Task SetAsync(string mode) =>
        _current = await JS.InvokeAsync<string>("agTheme.set", mode);
}
