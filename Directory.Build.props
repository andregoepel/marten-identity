<Project>
  <PropertyGroup>
    <Authors>André Göpel</Authors>
    <Copyright>© André Göpel</Copyright>
    <RepositoryUrl>https://github.com/andregoepel/marten-identity</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/andregoepel/marten-identity</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <!-- Generate and honour packages.lock.json so restores are reproducible and
         tamper-evident; CI restores in locked mode to fail on any drift (#36). -->
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
  </PropertyGroup>
</Project>
