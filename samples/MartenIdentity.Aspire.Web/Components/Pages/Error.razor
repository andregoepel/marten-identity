@page "/Error"
@inject IStringLocalizer<Strings> L

<PageTitle>@L["Error.PageTitle"]</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 720px;">
    <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H3">@L["Error.Heading"]</RadzenText>
    <RadzenText TextStyle="TextStyle.Body1">
        @L["Error.Message"]
    </RadzenText>
    <RadzenLink Path="/" Text="@L["Error.BackToHome"]" />
</RadzenStack>
