@page "/"
@* The library's cookie-login middleware redirects here (DefaultRedirect = "/dashboard")
   after a successful sign-in when no explicit ReturnUrl was supplied. *@
@page "/dashboard"
@inject IStringLocalizer<Strings> L

<PageTitle>@L["Home.PageTitle"]</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 720px;">
    <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H3">@L["Home.PageTitle"]</RadzenText>

    <RadzenText TextStyle="TextStyle.Body1">
        @L["Home.DescriptionPrefix"]
        <RadzenLink Path="https://github.com/andregoepel/marten-identity"
                    Text="AndreGoepel.Marten.Identity" Target="_blank" />@L["Home.DescriptionSuffix"]
    </RadzenText>

    <AuthorizeView>
        <Authorized>
            <RadzenText TextStyle="TextStyle.Body1">
                @L["Home.SignedInAsPrefix"] <strong>@context.User.Identity?.Name</strong>@L["Home.SignedInAsSuffix"]
            </RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                <RadzenLink Path="Account/Manage/Profile" Text="@L["Home.ManageAccount"]" />
                <AuthorizeView Roles="@Roles.Administrator" Context="admin">
                    <RadzenLink Path="Administration/Users" Text="@L["Home.AdministerUsers"]" />
                </AuthorizeView>
            </RadzenStack>
        </Authorized>
        <NotAuthorized>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                <RadzenLink Path="Account/Login" Text="@L["Home.LogIn"]" />
                <RadzenLink Path="Account/Register" Text="@L["Home.Register"]" />
            </RadzenStack>
        </NotAuthorized>
    </AuthorizeView>
</RadzenStack>

@code {
    // Set the topbar breadcrumb for the landing page (see MainLayout's BreadcrumbState).
    [CascadingParameter]
    private BreadcrumbState? Breadcrumb { get; set; }

    protected override void OnParametersSet() => Breadcrumb?.Set("Home");
}
