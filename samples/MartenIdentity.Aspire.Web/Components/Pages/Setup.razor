@page "/Setup"
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@layout LoginLayout

@using AndreGoepel.Marten.Identity
@using AndreGoepel.Marten.Identity.Blazor.Components.Layout
@using AndreGoepel.Marten.Identity.Services
@using Marten
@using Microsoft.AspNetCore.Identity

@inject UserManager<User> UserManager
@inject IIdentityAuthorizer Authorizer
@inject IQuerySession QuerySession
@inject NavigationManager Nav
@inject IStringLocalizer<Strings> L

<PageTitle>@L["Setup.PageTitle"]</PageTitle>

<div class="ag-login-head">
    <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4" Text="@L["Setup.Heading"]" />
    <RadzenText TextStyle="TextStyle.Body2" class="ag-login-sub"
                Text="@L["Setup.Subheading"]" />
</div>

@if (errors.Count > 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false">
        <ul style="margin: 0; padding-left: 1.2rem;">
            @foreach (var error in errors)
            {
                <li>@error</li>
            }
        </ul>
    </RadzenAlert>
}

<RadzenTemplateForm TItem="Model" Data="@model" Submit="@OnSubmitAsync">
    <RadzenStack Gap="1.25rem">
        <RadzenStack Gap="0.4rem">
            <RadzenLabel Text="@L["Setup.EmailLabel"]" Component="Email" />
            <RadzenTextBox @bind-Value="model.Email" Name="Email"
                           Placeholder="name@example.com" autocomplete="username" Style="width:100%" />
        </RadzenStack>
        <RadzenStack Gap="0.4rem">
            <RadzenLabel Text="@L["Setup.PasswordLabel"]" Component="Password" />
            <RadzenPassword @bind-Value="model.Password" Name="Password"
                            autocomplete="new-password" Style="width:100%" />
        </RadzenStack>
        <RadzenStack Gap="0.4rem">
            <RadzenLabel Text="@L["Setup.ConfirmPasswordLabel"]" Component="ConfirmPassword" />
            <RadzenPassword @bind-Value="model.ConfirmPassword" Name="ConfirmPassword"
                            autocomplete="new-password" Style="width:100%" />
        </RadzenStack>
        <div class="ag-login-actions">
            <RadzenButton ButtonType="ButtonType.Submit" Text="@L["Setup.CreateButton"]"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@busy" IsBusy="@busy" BusyText="@L["Setup.CreatingBusyText"]" />
        </div>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    private readonly Model model = new();
    private readonly List<string> errors = new();
    private bool busy;

    protected override async Task OnInitializedAsync()
    {
        // Defence in depth: the redirect middleware already blocks /Setup once an
        // administrator exists, but re-check here too (per the library's guidance).
        if (await SetupCompletion.IsCompleteAsync(QuerySession))
        {
            Nav.NavigateTo("/", forceLoad: true);
        }
    }

    private async Task OnSubmitAsync(Model _)
    {
        errors.Clear();

        if (string.IsNullOrWhiteSpace(model.Email))
            errors.Add(L["Setup.EmailRequired"]);
        if (string.IsNullOrEmpty(model.Password) || model.Password.Length < 12)
            errors.Add(L["Setup.PasswordMinLength"]);
        if (model.Password != model.ConfirmPassword)
            errors.Add(L["Setup.PasswordMismatch"]);
        if (errors.Count > 0)
            return;

        busy = true;
        try
        {
            // Trusted first-run bootstrap: BeginSystemScope lets the privileged store
            // operations run while no administrator exists yet. The scope is ambient across
            // the awaits below.
            using (Authorizer.BeginSystemScope())
            {
                // Mark this account as the root user. The library then owns the whole
                // "un-deletable root administrator" guarantee in one transaction: it forces
                // the account non-deletable, creates the Administrator role as a protected,
                // non-deletable role, and assigns it — so the first admin and the role that
                // anchors it can never be deleted (#41). Do NOT create the role or assign it
                // manually here; that historically left both deletable.
                var user = new User { UserName = model.Email, Email = model.Email, RootUser = true };
                var createResult = await UserManager.CreateAsync(user, model.Password);
                if (!createResult.Succeeded)
                {
                    AddIdentityErrors(createResult);
                    return;
                }

                // Sign-in requires a confirmed account (RequireConfirmedAccount = true).
                var token = await UserManager.GenerateEmailConfirmationTokenAsync(user);
                var confirmResult = await UserManager.ConfirmEmailAsync(user, token);
                if (!confirmResult.Succeeded)
                {
                    AddIdentityErrors(confirmResult);
                    return;
                }
            }

            // Setup is complete. A full-page navigation lets the redirect middleware
            // re-evaluate and route the now-unreachable /Setup path onward.
            Nav.NavigateTo("Account/Login", forceLoad: true);
        }
        finally
        {
            busy = false;
        }
    }

    private void AddIdentityErrors(IdentityResult result)
    {
        foreach (var error in result.Errors)
            errors.Add(error.Description);
    }

    private sealed class Model
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
